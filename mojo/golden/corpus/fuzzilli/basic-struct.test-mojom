module golden;

interface Primary {
  UseStruct(LargeStruct struct_param, uint64 id);
  GetStruct(string value) => (SimpleStruct result);
};

struct LargeStruct {
  uint64 id;
  string value;
  SimpleStruct residence;
  bool valid;
};

struct SimpleStruct {
  string field;
};
