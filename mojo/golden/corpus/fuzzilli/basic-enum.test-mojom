module golden;

interface Primary {
  enum NestedEnum {
    kThis,
    kThat,
  };

  GetEnum(string name) => (NestedEnum result);
  EnumForEnum(NestedEnum enum_param) => (ExternalEnum enum_result);
};

enum ExternalEnum {
  kHere,
};
