import("//tools/grit/grit_rule.gni")

source_ids = "//third_party/usb_ids/src/usb.ids"
generated_blob = "$target_gen_dir/usb_ids.dat"

# Generates a compact binary lookup blob from usb.ids. The blob is packaged
# into a Chrome resource by ":usb_ids_resources" below and loaded at runtime
# via ResourceBundle.
action("usb_device_ids") {
  script = "//services/device/public/cpp/usb/tools/usb_ids.py"
  inputs = [ source_ids ]
  outputs = [ generated_blob ]
  args = [
    "-i",
    rebase_path(source_ids, root_build_dir),
    "-o",
    rebase_path(generated_blob, root_build_dir),
  ]
}

grit("usb_ids_resources") {
  source = "resources/usb_ids_resources.grd"
  outputs = [
    "grit/usb_ids_resources.h",
    "usb_ids_resources.pak",
  ]
  deps = [ ":usb_device_ids" ]
  use_brotli = true

  # Reference the generated blob from the gen dir.
  grit_flags = [
    "-E",
    "root_gen_dir=" + rebase_path(root_gen_dir, root_build_dir),
  ]
}

# Copies the usb_ids_resources.pak out to $root_out_dir so that tests (which
# look in DIR_ASSETS) can load it directly via AddDataPackFromPath.
copy("usb_ids_resources_data") {
  sources = [ "$target_gen_dir/usb_ids_resources.pak" ]
  outputs = [ "$root_out_dir/usb_ids_resources.pak" ]
  deps = [ ":usb_ids_resources" ]
}

source_set("usb") {
  sources = [
    "usb_ids.cc",
    "usb_ids.h",
    "usb_utils.cc",
    "usb_utils.h",
  ]

  configs += [ "//build/config/compiler:wexit_time_destructors" ]

  # ':usb_ids_resources' is public so that dependents (including the
  # unittest) can include the generated grit header for IDR_USB_IDS_DATA.
  public_deps = [ ":usb_ids_resources" ]

  deps = [
    "//base",
    "//services/device/public/mojom:usb",
    "//ui/base",
  ]
}
