# Must be a component, not a source_set: a source_set is statically linked
# into every dependent component (e.g. content.dll and components_viz_host.dll),
# giving each its own copy of this target's process-wide singletons. A
# component keeps a single shared copy.
component("host") {
  sources = [
    "weights_file_creator_impl.cc",
    "weights_file_creator_impl.h",
    "weights_file_provider.cc",
    "weights_file_provider.h",
  ]

  defines = [ "IS_WEBNN_HOST_IMPL" ]

  deps = [
    "//base",
    "//mojo/public/cpp/bindings",
    "//services/webnn/public/mojom",
  ]

  if (is_win) {
    sources += [
      "execution_provider_initializer.cc",
      "execution_provider_initializer.h",
    ]

    deps += [
      "//services/webnn:webnn_switches",
      "//services/webnn/public/cpp:win",
      "//services/webnn/public/mojom",
      "//third_party/windows_app_sdk_headers",
    ]
  }
}
