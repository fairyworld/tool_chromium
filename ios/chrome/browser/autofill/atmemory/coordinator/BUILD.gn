source_set("coordinator") {
  sources = [
    "at_memory_coordinator.h",
    "at_memory_coordinator.mm",
    "at_memory_mediator.h",
    "at_memory_mediator.mm",
  ]
  deps = [
    "//ios/chrome/browser/autofill/atmemory/public",
    "//ios/chrome/browser/autofill/atmemory/ui",
    "//ios/chrome/browser/shared/coordinator/chrome_coordinator",
    "//ios/chrome/browser/shared/model/browser",
    "//ios/chrome/browser/shared/public/commands",
    "//ios/chrome/common/ui/colors",
    "//ios/public/provider/chrome/browser/keyboard:keyboard_api",
    "//ui/base",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "at_memory_mediator_unittest.mm" ]
  deps = [
    ":coordinator",
    "//ios/chrome/browser/autofill/atmemory/ui",
    "//testing/gtest",
    "//third_party/ocmock",
  ]
}
