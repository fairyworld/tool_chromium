import("//mojo/public/tools/bindings/mojom.gni")

mojom("mojom") {
  sources = [ "bookmarks_api.mojom" ]

  public_deps = [
    "//mojo/public/mojom/base",
    "//url/mojom:url_mojom_gurl",
  ]

  webui_module_path = "/"
}

source_set("bookmarks") {
  sources = [ "bookmarks_service.h" ]

  public_deps = [ ":mojom" ]

  deps = [
    "//base",
    "//components/bookmarks/browser",
    "//url",
  ]
}

source_set("impl") {
  sources = [
    "bookmarks_service_impl.cc",
    "bookmarks_service_impl.h",
  ]

  deps = [
    ":bookmarks",
    "//base",
    "//components/bookmarks/browser",
    "//url",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "bookmarks_service_impl_unittest.cc" ]

  deps = [
    ":bookmarks",
    ":impl",
    "//base/test:test_support",
    "//components/bookmarks/browser",
    "//components/bookmarks/test",
    "//testing/gtest",
    "//url",
  ]
}
