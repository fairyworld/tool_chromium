module bookmarks_api.mojom;


import "mojo/public/mojom/base/empty.mojom";
import "mojo/public/mojom/base/error.mojom";
import "mojo/public/mojom/base/uuid.mojom";
import "url/mojom/url.mojom";

// Represents a permanent folder type. The existence of a non-unknown value
// means that this is a special permanent node managed by the system.
enum PermanentFolderType {
  kUnknown,
  kBookmarkBar,
  kOther,
  kMobile,
  kManaged,
};

// Represents the root node of the bookmarks hierarchy.
struct RootNode {
  mojo_base.mojom.Uuid id;
  array<Folder> children;
};

// Represents a node in the bookmarks hierarchy.
union BookmarkNode {
  Url url;
  Folder folder;
};

// Represents a url node.
struct Url {
  // Not set if creating a new resource.
  mojo_base.mojom.Uuid? id;
  string title;
  url.mojom.Url url;
  url.mojom.Url? favicon_url;
  // True if the bookmark is synced to the account storage (i.e. it is not a
  // local-only node).
  bool is_synced;
};

// Represents a folder node.
struct Folder {
  // Not set if creating a new resource.
  mojo_base.mojom.Uuid? id;
  string title;
  array<BookmarkNode> children;
  PermanentFolderType? permanent_folder_type;
  // True if the folder is synced to the account storage (i.e. it is not a
  // local-only node).
  bool is_synced;
};

struct BookmarksSnapshot {
  RootNode root;
  // Updates to bookmarks would be sent through this update stream. Clients may
  // subscribe to this stream to receive update events.
  // The interface is associated with the interface used to retrieve this
  // stream. This means that the ordering of the message between the remote
  // and the observation stream is preserved.
  pending_associated_receiver<BookmarksObserver> stream;
};

struct BookmarkNodeCreated {
  mojo_base.mojom.Uuid parent_id;
  int32 index;
  BookmarkNode node;
};

struct BookmarkNodeRemoved {
  mojo_base.mojom.Uuid id;
};

struct BookmarkNodeMoved {
  mojo_base.mojom.Uuid old_parent_id;
  int32 old_index;
  mojo_base.mojom.Uuid new_parent_id;
  int32 new_index;
};

struct BookmarkNodeChanged {
  BookmarkNode node;
};

union BookmarksEvent {
  BookmarkNodeCreated added;
  BookmarkNodeRemoved removed;
  BookmarkNodeMoved moved;
  BookmarkNodeChanged changed;
};

interface BookmarksObserver {
  OnBookmarksEvents(array<BookmarksEvent> events);
};

[GenerateDirectReturnStub]
interface BookmarksService {
  // Gets the root bookmark node (which contains all folders/bookmarks) and
  // subscribes to future updates.
  GetBookmarks() => result<BookmarksSnapshot, mojo_base.mojom.Error>;

  // Get a specific bookmark node by ID.
  GetBookmark(mojo_base.mojom.Uuid id)
      => result<BookmarkNode, mojo_base.mojom.Error>;

  // Creates a new bookmark node.
  // If index is not provided, the node is appended to the end of the folder.
  // The parent_id must refer to a folder node.
  CreateBookmarkNode(
      // The folder to contain the bookmark node.
      mojo_base.mojom.Uuid parent_id,
      // The index the node should be placed in the parent node.
      int32? index,
      // The node object to create.
      BookmarkNode node) => result<BookmarkNode, mojo_base.mojom.Error>;

  // Updates an existing bookmark node.
  // The node to update is identified by the ID in `node`.
  // All mutable fields provided in `node` will be applied.
  UpdateBookmarkNode(BookmarkNode node)
      => result<BookmarkNode, mojo_base.mojom.Error>;

  // Moves a bookmark node to a new parent folder.
  // If index is not provided, the node is appended to the end of the folder.
  MoveBookmarkNode(mojo_base.mojom.Uuid id,
                   mojo_base.mojom.Uuid new_parent_id,
                   int32? index)
      => result<mojo_base.mojom.Empty, mojo_base.mojom.Error>;

  // Deletes multiple bookmark nodes.
  // IDs must not refer to permanent nodes.
  DeleteBookmarkNodes(array<mojo_base.mojom.Uuid> ids)
      => result<mojo_base.mojom.Empty, mojo_base.mojom.Error>;
};
