import "mojo/public/mojom/base/time.mojom";
import "ui/gfx/range/mojom/range.mojom";

// The context menu types that can be opened with ToolbarUIService's
// ShowContextMenu.
enum ContextMenuType {
  kUnspecified,
  // Navigation control buttons
  kReload,
  kSplitTabsAction,
  kSplitTabsContext,
  kBack,
  kForward,
  kHome,
  kBatterySaver,

  // Pinned toolbar action buttons
  kPinnedActionNewIncognitoWindow,
  kPinnedActionShowPasswordsBubbleOrPage,
  kPinnedActionShowPaymentsBubbleOrPage,
  kPinnedActionShowAddressesBubbleOrPage,
  kPinnedActionSidePanelShowBookmarks,
  kPinnedActionSidePanelShowReadingList,
  kPinnedActionSidePanelShowHistoryCluster,
  kPinnedActionShowDownloads,
  kPinnedActionClearBrowsingData,
  kPinnedActionPrint,
  kPinnedActionSidePanelShowLensOverlayResults,
  kPinnedActionShowTranslate,
  kPinnedActionQrCodeGenerator,
  kPinnedActionRouteMedia,
  kPinnedActionSidePanelShowReadAnything,
  kPinnedActionCopyUrl,
  kPinnedActionSendTabToSelf,
  kPinnedActionTaskManager,
  kPinnedActionDevTools,
  kPinnedActionTabSearch,
  kPinnedActionSidePanelShowContextualTasks,
  kPinnedActionSidePanelShowLens,
  kPinnedActionSidePanelShowAboutThisSite,
  kPinnedActionSidePanelShowCustomizeChrome,
  kPinnedActionSidePanelShowShoppingInsights,
  kPinnedActionSidePanelShowMerchantTrust,
  kPinnedActionSendSharedTabGroupFeedback,
  kPinnedActionSidePanelShowComments,
  // App Menu Button
  kAppMenu,
};

struct BackForwardButtonState {
  bool enabled;
  bool should_be_shown;
  bool is_context_menu_visible;
};

enum SplitTabActiveLocation {
  kUnspecified,
  kStart,
  kEnd,
  kTop,
  kBottom,
};

enum ToolbarButtonType {
  kUnspecified,
  kSplitTabs,
  kHome,
};

struct OmniboxActionFocusChange {
  bool has_focus = false;

  // If true, requests that search keyword be cleared. Applies only if
  // `has_focus` = true.
  bool request_clear_keyword = false;

  // If true, requests that search keyword be set to the default
  // search provider. Applies only if `has_focus` = true.
  bool activate_default_search = false;

  // If true, requests that zero suggest be started. Applies only if
  // `has_focus` = true.
  bool start_zero_suggest = false;

  gfx.mojom.Range selection;
};

struct OmniboxActionTextInput {
  // The entire user-entered text (not including any displayed inline
  // autocompletion). Should be considered untrusted.
  mojo_base.mojom.String16 text;

  // The unaccepted portion of inline autocompletion. (May be a suffix of
  // what the model suggested if the user typed some of the expected
  // characters).
  mojo_base.mojom.String16 inline_autocompletion;

  // The version of the input on the browser side, incremented when the
  // state is reset due to navigation or selection from completion popup.
  // (Wraparound is OK, it looks for equality).
  uint32 browser_version;

  // The version of the input on the WebUI side, incremented when user
  // interaction changed the displayed text.
  // (Wraparound is OK, it looks for equality).
  // TODO(crbug.com/503784450): Decide whether we have to increment it for
  // selection changes as well.
  uint32 ui_version;

  gfx.mojom.Range selection;
};

struct OmniboxActionKey {
  // True if this is a key down event, false if it's key up.
  bool is_key_down = true;

  // KeyboardEvent.key of the event; nothing else should be stored in this
  // field.
  string key;
  gfx.mojom.Range selection;

  // Modifier keys held during event.
  array<browser_controls_api.mojom.EventDispositionFlag> modifiers;
};

// Used to notify the browser process that the user has either pressed or
// released the mouse on the omnibox.
struct OmniboxActionMouse {
  bool is_mouse_down = false;

  // If true, asks for zero-suggest completion to start. Applies only if
  // `is_mouse_down` is false.
  bool start_zero_suggest = false;
};

// Sent from the WebUI to the browser to notify of relevant input.
union OmniboxAction {
  OmniboxActionFocusChange focus_change;
  OmniboxActionTextInput text_input;
  OmniboxActionKey key;
  OmniboxActionMouse mouse;
};

struct ReloadControlState {
  // The maximum delay for a double click. If there's a longer delay than this,
  // it should be treated as two separate clicks.
  mojo_base.mojom.TimeDelta double_click_interval;

  bool can_show_menu;
  bool is_navigation_loading;
  bool is_context_menu_visible;

  // This changes whenever the state should be reset, typically due to a change
  // in context (i.e., a switch between tabs). When a `state_token` is received
  // that has different from the most recently recently received token, the
  // reload button icon changes immediately to the state corresponding to the
  // value of `is_navigation_loading`, ignoring all debouncing logic and double
  // click delays, and any timers are stopped.
  int32 state_token;
};

struct SplitTabsControlState {
  bool is_current_tab_split;
  SplitTabActiveLocation location;
  bool is_pinned;
  bool is_context_menu_visible;
};

struct BackForwardControlState {
  BackForwardButtonState back_button_state;
  BackForwardButtonState forward_button_state;
  int32 back_button_leading_margin;
};

struct HomeControlState {
  bool should_be_shown;
  bool is_context_menu_visible;
};

// The type of icon state for the app menu. These values drive the visual
// "chip" state (colored background + label) but do not change the underlying
// three-dot icon glyph.
// (See AppMenuIconController::IconType in
//  chrome/browser/ui/toolbar/app_menu_icon_controller.h)
enum AppMenuIconType {
  kNone,
  kUpgradeNotification,
  kGlobalError, // e.g. sign-in error.
};

// The severity level of the app menu icon (e.g., for updates or errors).
// This determines the background color and text color of the chip in WebUI.
// (See AppMenuIconController::Severity in
//  chrome/browser/ui/toolbar/app_menu_icon_controller.h)
enum AppMenuSeverity {
  kNone,
  kLow,
  kMedium,
  kHigh,
};

// The state of the app menu control.
struct AppMenuControlState {
  AppMenuIconType icon_type;
  AppMenuSeverity severity;

  // Text to show in control, if any.
  mojo_base.mojom.String16? label_text;

  // Accessible name (aria-label).
  mojo_base.mojom.String16 accessibility_text;

  // Tooltip text to display on hover.
  mojo_base.mojom.String16 tooltip;

  bool is_context_menu_visible;

  // The trailing margin for the app menu control.
  int32 trailing_margin;
};

enum AvatarToolbarButtonState {
  kGuestSession,
  kIncognitoProfile,
  kExplicitTextShowing,
  kOnSignin,
  kShowIdentityName,
  kSigninPending,
  kSyncPaused,
  kUpgradeClientError,
  kPassphraseError,
  kBookmarksLimitExceeded,
  kSyncError,
  kPasskeysLockedError,
  kPromo,
  kManagement,
  kNormal,
};

struct AvatarControlState {
  AvatarToolbarButtonState state;
  string icon_url;
  mojo_base.mojom.String16 text;
  mojo_base.mojom.String16 tooltip;
  mojo_base.mojom.String16 accessibility_name;
  mojo_base.mojom.String16 accessibility_description;
  bool enabled = true;
};

// The type of the content setting image model.
//
// Unlike ContentSettingsType, which defines the underlying settings, this enum
// defines the icon to display.  This distinction matters for things like
// kFramebust (iframe tried to navigate the top-level frame without user
// activation and was blocked), which has a separate icon from kPopups
// (window.open() called without user activation and was blocked), even though
// they share the same underlying setting to disable blocking.
//
// Therefore, this enum is UI-specific, unlike ContentSettingsType.
enum ContentSettingImageType {
  kCookies = 0,
  kImages = 1,
  kJavaScript = 2,
  // kPpapiBroker = 3, // Deprecated.
  kPopups = 5,
  kGeolocation = 6,
  kMixedScript = 7,
  kProtocolHandlers = 8,
  kMediaStream = 9,
  kAds = 10,
  kAutomaticDownloads = 11,
  kMidiSysex = 12,
  kSound = 13,
  kFramebust = 14,
  // kClipboardRead = 15, // Replaced by kClipboardReadWrite in M81.
  kSensors = 16,
  // kNotificationsQuietPrompt = 17, // Replaced by kNotifications in M124
  kClipboardReadWrite = 18,
  kStorageAccess = 19,
  // kMidi = 20, // Deprecated.
  kNotifications = 21,
  [EnableIf=is_chromeos]
  kSmartCard = 22,
  [EnableIf=is_win]
  kProtectedMediaIdentifier = 23,
};

// These fields correspond to the accessors of ContentSettingImageModel.
struct ContentSettingImageState {
  // The specific content setting icon button to display, described by this
  // state.
  ContentSettingImageType type;

  // Accessible name for the icon. If empty, `tooltip` is used instead.
  mojo_base.mojom.String16 accessibility_string;

  // Mouseover popup text to display over icon.
  mojo_base.mojom.String16 tooltip;

  // Indicates that the content setting has been blocked (that is, disabled) by
  // the user (i.e. turn off JavaScript) -- the icon should change to indicate
  // the blocked status.
  bool is_blocked;

  // If true, the bubble is visible, so the icon should be highlighted.
  //
  // TODO: crbug.com/489109708 - Consider removing `should_run_animation` if we
  // can use element tracking for highlighting instead.
  bool is_bubble_visible;

  // TODO: crbug.com/489109708 - For stateful property below, we'll need to
  // send an incrementing generation number instead, as updates can be
  // consolidated, and check against the last known number on the WebUI side.
  // This prevents an issue where the initial message (run animation) gets lost
  // in consolidation.

  // If true, when `explanitory_string` is displayed, it should appear via an
  // animation.
  bool should_run_animation;

  // Explanatory text that animates in if `should_run_animation` is true.
  mojo_base.mojom.String16 explanatory_string;

  // NOTE: The visual icon to display is determined by `type`
  // and `is_blocked`.
};

// LINT.IfChange(PageActionId)
// Enum of all page actions listed in kPageActionProperties.
enum PageActionId {
  kActionAiMode,
  kActionIndigo,
  kActionMultistepFilter,
  kActionSidePanelShowLensOverlayResults,
  kActionLensOverlayHomework,
  kActionShowTranslate,
  kActionShowMemorySaverChip,
  kActionShowJsOptimizationsIcon,
  kActionRecordReplay,
  kActionShowIntentPicker,
  kActionZoomNormal,
  kActionSidePanelShowReadAnything,
  kActionOffersAndRewardsForPage,
  kActionShowFileSystemAccess,
  kActionInstallPwa,
  kActionCommercePriceInsights,
  kActionCommerceDiscounts,
  kActionShowPasswordsBubbleOrPage,
  kActionShowCollaborationRecentActivity,
  kActionAutofillMandatoryReauth,
  kActionFind,
  kActionShowCookieControls,
  kActionShowAddressesBubbleOrPage,
  kActionVirtualCardEnroll,
  kActionFilledCardInformation,
  kActionShowPaymentsBubbleOrPage,
  kActionSidePanelShowContextualTasks,
  kActionBookmarkThisTab,
  kActionFederation,
  kActionGlicContextualCueing,
  kActionAnchoredContextualCue,
  kActionWebAuthnAmbientSignin,
