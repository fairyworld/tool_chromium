<translation id="1131201598497838573">PIN anak anda telah dikemaskinikan</translation>
<translation id="1147322039136785890">Kini giliran <ph name="SUPERVISED_USER_NAME" /> pula</translation>
<translation id="1176864681932214421">Buat imej dengan AI</translation>
