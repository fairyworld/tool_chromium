<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1005333234656240382">‏להפעיל ניפוי באגים באמצעות ADB?</translation>
<translation id="1076766328672150609">לילד או לילדה שלך יש אפשרות להשתמש בקוד אימות כדי לבטל את נעילת המכשיר הזה.</translation>
<translation id="1097658378307015415">לפני הכניסה לחשבון, יש להיכנס כאורח כדי להפעיל את הרשת <ph name="NETWORK_ID" /></translation>
<translation id="1111932478203988717">לילד או לילדה שלך יש אפשרות להשתמש בקוד האימות הזה כדי להיכנס למכשיר שלהם</translation>
<translation id="1122587596907914265">עיצוב טפטים ייחודיים</translation>
<translation id="1131201598497838573">קוד האימות של הילד או הילדה עודכן</translation>
<translation id="1147322039136785890">עכשיו התור של <ph name="SUPERVISED_USER_NAME" /></translation>
<translation id="1176864681932214421">‏יצירת תמונות באמצעות AI</translation>
<translation id="1177073277575830464">‏ההגדרה המהירה של Android הושלמה. צריך להמשיך את ההגדרה במכשיר <ph name="DEVICE_TYPE" />.</translation>
<translation id="1179902906564467236">צריך לפעול לפי ההוראות בטלפון או להשתמש באפליקציית המצלמה</translation>
<translation id="1185924365081634987">כדאי גם לנסות <ph name="GUEST_SIGNIN_LINK_START" />לגלוש כאורח<ph name="GUEST_SIGNIN_LINK_END" /> כדי לתקן את שגיאת הרשת הזו.</translation>
<translation id="1201402288615127009">הבא</translation>
<translation id="1222835797152767346">אפשר להגדיר קוד אימות כדי שיהיה יותר קל להיכנס לחשבון</translation>
<translation id="1346669614038013595">‏<ph name="BEGIN_H3" />תכונות לניפוי באגים<ph name="END_H3" />
          <ph name="BR" />
          כדי להתקין ולבדוק קוד מותאם אישית במכשיר ה-ChromeOS שלך, יש לך אפשרות להפעיל תכונות לניפוי באגים במכשיר. הפעולה הזו תאפשר לך:<ph name="BR" />
          <ph name="BEGIN_LIST" />
            <ph name="LIST_ITEM" />להסיר אימות rootfs כדי לשנות קבצים של מערכת ההפעלה
            <ph name="LIST_ITEM" />להפעיל גישת SSH למכשיר באמצעות מפתחות הבדיקה הרגילים, כדי שאפשר יהיה לגשת למכשיר באמצעות כלים כמו <ph name="BEGIN_CODE" />cros flash<ph name="END_CODE" />
            <ph name="LIST_ITEM" />להפעיל אתחול מ-USB כדי שאפשר יהיה להתקין קובץ אימג' של מערכת ההפעלה מכונן USB
            <ph name="LIST_ITEM" />להגדיר את סיסמת הכניסה של המפתח וגם של הרמה הבסיסית (root) לערך מותאם אישית כדי להתחבר ידנית למכשיר באמצעות SSH
          <ph name="END_LIST" />
          <ph name="BR" />
          לאחר ההפעלה של התכונות לניפוי באגים, רובן יישארו מופעלות גם לאחר ביצוע Powerwash או איפוס של הנתונים במכשיר שמנוהל בארגון. כדי להשבית את כל התכונות לניפוי באגים במלואן, צריך לבצע את תהליך השחזור של ChromeOS ‏(https://support.google.com/chromebook/answer/1080595).
          <ph name="BR" />
          <ph name="BR" />
          מידע נוסף על התכונות לניפוי באגים מופיע בכתובת:<ph name="BR" />
          https://www.chromium.org/chromium-os/how-tos-and-troubleshooting/debugging-features
          <ph name="BR" />
          <ph name="BR" />
          <ph name="BEGIN_BOLD" />הערה:<ph name="END_BOLD" /> המערכת תבצע הפעלה מחדש בזמן התהליך.</translation>
<translation id="1347625331607114917">‏אימות הקוד בטלפון Android</translation>
<translation id="1347975661240122359">העדכון יתחיל כשהסוללה תיטען ל-%<ph name="BATTERY_LEVEL" />.</translation>
<translation id="1375938286942050085">ההגדרה הושלמה. עכשיו אפשר להכין את המכשיר לגיימינג</translation>
<translation id="1377600615067678409">דילוג לעת עתה</translation>
<translation id="1400243387594338234">אפשר להשתמש בקוד האימות הזה כדי להיכנס למכשיר</translation>
<translation id="1426410128494586442">כן</translation>
<translation id="1473927070149284123">אפשר לנסות שוב או להתחבר לרשת באופן ידני</translation>
<translation id="1503556098270577657">‏נכנסת לחשבון <ph name="USER_EMAIL" /> באמצעות טלפון Android</translation>
<translation id="1521442365706402292">ניהול אישורים</translation>
<translation id="1572876035008611720">יש להזין את כתובת האימייל</translation>
<translation id="1642494467033190216">‏הסרה של הגנת rootfs והפעלה מחדש נדרשות לפני שמפעילים תכונות אחרות של ניפוי באגים.</translation>
<translation id="1678919064276516737">כתובת האימייל וקוד האימות שהזנת לא תואמים</translation>
<translation id="169675691788639886">‏למכשיר מוגדר שרת SSH. אין להיכנס לחשבונות רגישים.</translation>
<translation id="1730666151302379551">שכחתי את הסיסמה הישנה</translation>
<translation id="1826192255355608658">‏סנכרון הסימניות, הסיסמאות, ההיסטוריה והגדרות נוספות של דפדפן Chrome</translation>
<translation id="1831848493690504725">‏לא ניתן להתחבר ל-Google דרך הרשת המחוברת. אפשר לנסות לבחור רשת אחרת או לבדוק את הגדרות הרשת או ההגדרות לשרת ה-proxy (אם משתמשים בשרת proxy).</translation>
<translation id="1987574314042117472">בחירה והתקנה של האפליקציות הפופולריות</translation>
<translation id="2052572566310583903">מותקנת במכשירים אחרים שלך</translation>
<translation id="2090165459409185032">‏כדי לשחזר את המידע מהחשבון, יש לעבור אל: google.com/accounts/recovery</translation>
<translation id="2157779167749714207">‏מכשיר <ph name="DEVICE_TYPE" /> שלך מגיע עם Gemini</translation>
<translation id="2163470535490402084">צריך להתחבר לאינטרנט כדי להיכנס אל ה-<ph name="DEVICE_TYPE" />.</translation>
<translation id="2178585470774851578">‏פעולה זו מאפשרת פעילות של תכונות לניפוי באגים במערכת ההפעלה של ChromeOS Flex שיגדירו sshd daemon ויאפשרו אתחול מכונני USB.</translation>
<translation id="2219081237089444028">מגדירים סיסמה ל-<ph name="DEVICE_TYPE" /> ונכנסים לחשבון בקלות</translation>
<translation id="2296022312651137376">התקבלה דרישה מהדומיין <ph name="DOMAIN_NAME" /> שהמכשיר יהיה אונליין כשנכנסים לחשבון <ph name="EMAIL" /></translation>
<translation id="2317842250900878657">%<ph name="PROGRESS_PERCENT" />הושלמו</translation>
<translation id="2319072477089403627">‏מתבצע חיבור לטלפון Android…</translation>
<translation id="2328137272841210255">איפוס קוד האימות שלך</translation>
<translation id="2342180549977909852">לילד או לילדה שלך יש אפשרות להשתמש במספר (קוד אימות) במקום בסיסמה כדי לבטל את נעילת המכשיר הזה. ניתן להגדיר את הקוד מאוחר יותר ב'הגדרות'.</translation>
<translation id="2359808026110333948">המשך</translation>
<translation id="2408955596600435184">יש להזין את קוד האימות</translation>
<translation id="2439152382014731627">איפוס הסיסמה ל-<ph name="DEVICE_TYPE" /></translation>
<translation id="2450223707519584812">‏לא תהיה אפשרות להוסיף משתמשים מפני שהמפתחות של Google API חסרים. לפרטים, יש לעבור אל <ph name="DETAILS_URL" />.</translation>
<translation id="2582253231918033891"><ph name="PRODUCT_NAME" /> <ph name="PRODUCT_VERSION" /> (פלטפורמה <ph name="PLATFORM_VERSION" />‏) <ph name="DEVICE_SERIAL_NUMBER" /></translation>
<translation id="2725200716980197196">קישוריות הרשת התחדשה</translation>
<translation id="2731700343119398978">יש להמתין...</translation>
<translation id="2732134891301408122">תוכן נוסף של <ph name="CURRENT_ELEMENT" /> מתוך <ph name="TOTAL_ELEMENTS" /></translation>
<translation id="2740531572673183784">אישור</translation>
<translation id="2754825024506485820">‏בחנות Google Play ניתן למצוא את כל האפליקציות שצריכים, בכל התחומים – מפרודוקטיביות ועד בידור אפשר להתקין אפליקציות בכל שלב.</translation>
<translation id="2805539617243680210">הכול מוכן!</translation>
<translation id="2832124733806557606">לילד או לילדה שלך יש אפשרות להשתמש בקוד אימות כדי להיכנס למכשיר הזה או לבטל את הנעילה שלו.</translation>
<translation id="283669119850230892">כדי להשתמש ב-<ph name="NETWORK_ID" /> של הרשת, יש להשלים קודם את ההתחברות לאינטרנט, למטה.</translation>
<translation id="2849767214114481738">קוד האימות שלך נוסף</translation>
<translation id="2893180576842394309">‏Google עשויה להשתמש בהיסטוריית הגלישה שלך לצורך התאמה אישית של החיפוש ושירותי Google אחרים</translation>
<translation id="2904210161403910217">הסיסמה שלך השתנתה מאז הכניסה האחרונה לחשבון</translation>
<translation id="2921081876747860777">יצירת סיסמה להגנה על הנתונים המקומיים שלך.</translation>
<translation id="2950666755714083615">אני רוצה להירשם</translation>
<translation id="2979966855249721010">יכול להיות שיוצגו לך המלצות לאפליקציות, טיפים ועוד לפי תחומי העניין שלך</translation>
<translation id="3012917896646559015">יש ליצור קשר עם יצרן החומרה באופן מיידי כדי לשלוח את המחשב לתיקון.</translation>
<translation id="3028371505549235127">‏במקום להזין את הסיסמה לחשבון Google כדי להיכנס, אפשר ליצור סיסמה ל-<ph name="DEVICE_TYPE" /> למכשיר הזה</translation>
<translation id="3101924772906986970">‏הסימניות, הסיסמאות, ההיסטוריה והגדרות נוספות של דפדפן Chrome נשמרות בחשבון שלך ב-Google</translation>
<translation id="313205617302240621">שכחת את הסיסמה?</translation>
<translation id="3170072451822350649">ניתן גם לדלג על הכניסה ו<ph name="LINK_START" />לגלוש כאורח<ph name="LINK_END" />.</translation>
<translation id="3196912927885212665">‏כדי להגדיר באמצעות טלפון Android, צריך להפעיל את ה-Bluetooth של ה-Chromebook</translation>
<translation id="3238192140106069382">מתבצעים התחברות ואימות</translation>
<translation id="3261268979727295785">‏בחשבונות של ילדים בוגרים יותר יש לך אפשרות להוסיף בקרת הורים לאחר סיום ההגדרה. באפליקציה 'מה חדש ב-Chromebook' מפורט מידע נוסף על בקרת הורים.</translation>
<translation id="3278001907972365362">‏כדאי לבדוק אם צריך לבצע פעולה כלשהי בחשבונות Google שלך</translation>
<translation id="3283148363895519428">‏כדי להמשיך בהגדרה, עליך לפעול לפי ההוראות בטלפון. חשוב לוודא שהטלפון נמצא בקרבת מקום ושה-Bluetooth מופעל.</translation>
<translation id="3435896845095436175">הפעלה</translation>
<translation id="3462413494201477527">האם לבטל את הגדרת החשבון?</translation>
<translation id="3473241910002674503">במצב טאבלט אפשר להשתמש בכפתורים כדי לעבור אל דף הבית, לחזור לדף הקודם ולעבור בין אפליקציות.</translation>
<translation id="3491669675709357988">‏בחשבון של הילד או הילדה שלך לא מוגדרת בקרת הורים של Family Link. יש לך אפשרות להוסיף בקרת הורים לאחר סיום ההגדרה. באפליקציה 'מה חדש ב-Chromebook' מפורט מידע נוסף על בקרת הורים.</translation>
<translation id="3635199270495525546">‏זוהה מודול פלטפורמה מהימן (TPM)</translation>
<translation id="3661106764436337772">לכתוב מהר יותר ועם יותר ביטחון</translation>
<translation id="3662207097851752847">‏צריך לאשר את חשבון Google בטלפון</translation>
<translation id="3672681487849735243">אותרה שגיאה שמקורה ביצרן</translation>
<translation id="3673097791729989571">ספק הכניסה הוא <ph name="SAML_DOMAIN" /></translation>
<translation id="3673287357837016374">קוד האימות שלך עודכן</translation>
<translation id="367645871420407123">‏יש להשאיר ריק אם ברצונך להגדיר את סיסמת root לערך תמונת בדיקת ברירת המחדל</translation>
<translation id="3712050472459130149">יש לעדכן את החשבון</translation>
<translation id="3733296813637058299">‏נתקין את האפליקציות האלו בשבילך. אפליקציות נוספות בשביל <ph name="DEVICE_TYPE" /> זמינות בחנות Play.</translation>
<translation id="376841534249795524">למה ישמש אותך ה-<ph name="DEVICE_TYPE" />?</translation>
<translation id="3789841737615482174">התקנה</translation>
<translation id="385051799172605136">חזרה</translation>
<translation id="3897746662269329507">‏מכשיר <ph name="DEVICE_TYPE" /> מיועד למשחקים. בשלב הבא, תיפתח האפליקציה 'מה חדש ב-Chromebook', ובה תהיה לך גישה למאות משחקים עדכניים, למבצעים על משחקים ולתכונות הגיימינג של המכשיר.</translation>
<translation id="3910588685973519483">‏יצירת טפטים באמצעות AI</translation>
<translation id="3950820424414687140">כניסה</translation>
<translation id="3994318741694670028">‏לצערנו, המחשב שלך מוגדר באמצעות מזהה חומרה פגום. המצב הזה מונע מ-ChromeOS Flex להתקין את עדכוני האבטחה האחרונים, <ph name="BEGIN_BOLD" />ויכול להיות שהמחשב שלך יהיה חשוף להתקפות זדוניות<ph name="END_BOLD" />.</translation>
<translation id="4002440992267487163">הגדרת קוד אימות</translation>
<translation id="4044883420905480380">‏התחברת ל-Wi-Fi ונכנסת אל <ph name="USER_EMAIL" /> באמצעות טלפון Android</translation>
<translation id="4062561150282203854">סנכרון האפליקציות, ההגדרות ונתונים נוספים של <ph name="DEVICE_TYPE" /></translation>
<translation id="4089743381329341712">האפליקציות שבחרת יותקנו לאחר סיום ההגדרה. אפשר לקבל עוד המלצות בהמשך באפליקציה "אפליקציות ומשחקים".</translation>
<translation id="4104944259562794668">כדי להפעיל את התכונה הזו מאוחר יותר, עוברים אל 'הגדרות' &gt; 'אבטחה ופרטיות' &gt; 'מסך הנעילה וכניסה לחשבון'</translation>
<translation id="41365691917097717">‏בחירה להמשיך תגרום להפעלת ניפוי באגים באמצעות ADB במהלך היצירה והבדיקה של אפליקציות ל-Android. חשוב לשים לב שהפעולה הזו מאפשרת את ההתקנה של אפליקציות ל-Android שלא אומתו על ידי Google. כדי להשבית את התכונה, יש לאפס את המכשיר להגדרות המקוריות.</translation>
<translation id="4232484478444192782">‏יש כל מה שצריך בטלפון Android שלך. רשת ה-Wi-Fi והסיסמה מועברות.</translation>
<translation id="4242145785130247982">אין תמיכה באישורי לקוח מרובים.</translation>
<translation id="4250680216510889253">לא</translation>
<translation id="4263223596040212967">כדאי לבדוק את פריסת המקלדת ולנסות שוב.</translation>
<translation id="4289732974614035569">בחירת קוד אימות</translation>
<translation id="4317733381297736564">רכישות מתוך האפליקציות</translation>
<translation id="4370975561335139969">כתובת האימייל והסיסמה שהזנת אינן תואמות</translation>
<translation id="4373418556073552953">‏כניסה באמצעות טלפון Android</translation>
<translation id="4410545552906060960">אפשר להשתמש במספר (קוד) במקום בסיסמה כדי לבטל את נעילת המכשיר. ניתן להגדיר את הקוד מאוחר יותר ב'הגדרות'.</translation>
<translation id="4415213869328311284">ה-<ph name="DEVICE_TYPE" /> שלך מוכן לשימוש.</translation>
<translation id="4450974146388585462">אבחן</translation>
<translation id="445099924538929605">‏מערכת <ph name="DEVICE_OS" /> זיהתה TPM פעיל שניתן לשמור בו את הנתונים שלך באופן מאובטח יותר.</translation>
<translation id="4472575034687746823">תחילת העבודה</translation>
<translation id="4567512141633030272">אפשרות הכניסה שגויה?</translation>
<translation id="4568213207643490790">‏מצטערים, לא ניתן להשתמש בחשבונות Google במכשיר זה.</translation>
<translation id="4611759022973144129">אפשר להזין את הסיסמה הזו כדי להיכנס אל <ph name="DEVICE_TYPE" />.</translation>
<translation id="4727847987444062305">גלישה מנוהלת כאורח</translation>
<translation id="473775607612524610">עדכון</translation>
<translation id="473936925429402449">נבחר, תוכן נוסף <ph name="CURRENT_ELEMENT" /> מתוך <ph name="TOTAL_ELEMENTS" /></translation>
<translation id="4830502475412647084">‏מתקין עדכון OS</translation>
<translation id="4837926214103741331">אין לך אישור להשתמש במכשיר הזה. יש ליצור קשר עם בעל המכשיר כדי לקבל הרשאת כניסה.</translation>
<translation id="4864369630010738180">מתבצעת כניסה...</translation>
<translation id="4899696330053002588">מכילה מודעות</translation>
<translation id="4944310289250773232">שירות האימות הזה מתארח בדומיין <ph name="SAML_DOMAIN" /></translation>
<translation id="4955710816792587366">בחירת קוד</translation>
<translation id="5029287942302939687">הסיסמה הוגדרה</translation>
<translation id="503155457707535043">הורדת האפליקציות מתבצעת</translation>
<translation id="5045550434625856497">סיסמה שגויה</translation>
<translation id="5062930723426326933">הכניסה לחשבון נכשלה. צריך להתחבר לאינטרנט ולנסות שוב.</translation>
<translation id="5107486920067578245">‏<ph name="BEGIN_PARAGRAPH1" />רוצה להתחיל לכתוב, לתכנן, ללמוד ועוד בעזרת Google AI? כל מה שצריך הוא להתכתב בצ׳אט עם Gemini<ph name="END_PARAGRAPH1" />
        <ph name="BEGIN_PARAGRAPH2" />כדי להתחיל להשתמש ב-Gemini אחרי ההגדרה, אפשר לבחור את האפליקציה במדף, שנמצא בחלק התחתון של המסך.<ph name="END_PARAGRAPH2" /></translation>
<translation id="5115309401544567011">חבר את ה-<ph name="DEVICE_TYPE" /> למקור חשמל.</translation>
<translation id="5147516217412920887">כדי לאמת את הקוד, עליך לפעול לפי ההוראות בטלפון</translation>
<translation id="5160857336552977725">יש להיכנס אל ה-<ph name="DEVICE_TYPE" /></translation>
<translation id="5171185788583376591">‏<ph name="BEGIN_H3" />תכונות לניפוי באגים<ph name="END_H3" />
          <ph name="BR" />
          כדי להתקין ולבדוק קוד מותאם אישית במכשיר ה-ChromeOS Flex שלך, יש לך אפשרות להפעיל תכונות לניפוי באגים במכשיר. הצעד הזה יאפשר לך:<ph name="BR" />
          <ph name="BEGIN_LIST" />
            <ph name="LIST_ITEM" />להסיר אימות rootfs כדי לשנות קבצים של מערכת ההפעלה
            <ph name="LIST_ITEM" />להפעיל גישת SSH למכשיר באמצעות מפתחות הבדיקה הרגילים, באופן שיאפשר לך להשתמש בכלים כמו <ph name="BEGIN_CODE" />cros flash<ph name="END_CODE" /> לצורך גישה למכשיר
            <ph name="LIST_ITEM" />להפעיל אתחול מ-USB כדי שתהיה לך אפשרות להתקין קובץ אימג' של מערכת ההפעלה מכונן USB
            <ph name="LIST_ITEM" />להגדיר את סיסמת הכניסה של המפתח ואת סיסמת הרמה הבסיסית (root) לערך מותאם אישית כדי להתחבר ידנית למכשיר באמצעות SSH
          <ph name="END_LIST" />
          <ph name="BR" />
          לאחר ההפעלה של התכונות לניפוי באגים, רובן יישארו מופעלות גם לאחר ביצוע Powerwash או איפוס של הנתונים במכשיר שמנוהל בארגון.  כדי להשבית את כל התכונות לניפוי באגים במלואן, צריך להשלים את תהליך השחזור של ChromeOS ‏(https://support.google.com/chromebook/answer/1080595).
          <ph name="BR" />
          <ph name="BR" />
          מידע נוסף על התכונות לניפוי באגים מפורט בכתובת:<ph name="BR" />
          https://www.chromium.org/chromium-os/how-tos-and-troubleshooting/debugging-features
          <ph name="BR" />
          <ph name="BR" />
          <ph name="BEGIN_BOLD" />הערה:<ph name="END_BOLD" />  המערכת תבצע הפעלה מחדש בזמן התהליך.</translation>
<translation id="523505283826916779">הגדרות נגישות</translation>
<translation id="5240931875940563122">‏כניסה באמצעות טלפון Android</translation>
<translation id="5255859108402770436">כניסה חוזרת</translation>
<translation id="5260508466980570042">מצטערים, לא ניתן לאמת את האימייל או את הסיסמה שלך. יש לנסות שוב.</translation>
<translation id="5264252276333215551">יש להתחבר לאינטרנט כדי להפעיל את היישום במצב קיוסק.</translation>
<translation id="528208740344463258">‏צריך להתקין את העדכון הנדרש הזה כדי להוריד אפליקציות Android ולהשתמש בהן. לא יתאפשר לך להשתמש ב-<ph name="DEVICE_TYPE" /> בזמן העדכון. כשההתקנה תסתיים, ה-<ph name="DEVICE_TYPE" /> יופעל מחדש.</translation>
<translation id="542948651837270806">‏צריך להתקין עדכון לקושחה של Trusted Platform Module. יש לעיין בכתובת <ph name="TPM_FIRMWARE_UPDATE_LINK" /></translation>
<translation id="5448293924669608770">אופס. משהו השתבש בכניסה לחשבון</translation>
<translation id="5463450804024056231">הרשמה לקבלת אימיילים לגבי <ph name="DEVICE_TYPE" /></translation>
<translation id="5527474464531963247">אפשר גם לבחור רשת אחרת.</translation>
<translation id="5539070192556911367">‏לא ניתן להתחבר ל-Google</translation>
<translation id="557722062034137776">‏איפוס של המכשיר לא ישפיע על חשבונות Google שלך או על נתונים המסונכרנים לחשבונות אלה. אך כל הקבצים המאוחסנים במכשיר באופן מקומי יימחקו.</translation>
<translation id="5626172233890210551">אפשר גם להשתמש בסיסמה</translation>
<translation id="5636996382092289526">כדי להשתמש ב-<ph name="NETWORK_ID" /> ייתכן שראשית יהיה עליך <ph name="LINK_START" />להיכנס לדף הכניסה של הרשת<ph name="LINK_END" />, שייפתח אוטומטית בעוד כמה שניות. אם הוא לא נפתח, לא ניתן יהיה להשתמש ברשת.</translation>
<translation id="5659964844710667266">יצירת סיסמה למכשיר <ph name="DEVICE_TYPE" /></translation>
<translation id="5684950556880280580">הסיסמה שלך עודכנה</translation>
<translation id="5762787084360227629">‏הזנת פרטי חשבון Google</translation>
<translation id="5764797882307050727">יש לפנות מקום אחסון במכשיר.</translation>
<translation id="5765425701854290211">אנחנו מצטערים, אבל חלק מהקבצים נפגמו והעדכון לא הצליח. הקבצים המסונכרנים שלך לא נפגעו.</translation>
<translation id="5770125698810550803">הצגת כפתורי ניווט</translation>
<translation id="5799478978078236781">אפשר לקבל טיפים, מידע על מבצעים ועדכונים בנוגע ל-<ph name="DEVICE_TYPE" /> ולשתף משוב.</translation>
<translation id="5804259315582798390">נכשלה ההפעלה של שחזור הנתונים המקומיים</translation>
<translation id="5810809306422959727">החשבון הזה לא מתאים לבקרת הורים</translation>
<translation id="5852137567692933493">‏הפעלה מחדש וביצוע Powerwash</translation>
<translation id="5856721540245522153">הפעלת תכונות לניפוי באגים</translation>
<translation id="5860491529813859533">הפעלה</translation>
<translation id="5895138241574237353">הפעלה מחדש</translation>
<translation id="5895335062901455404">‏הפעילות וההעדפות השמורות שלך יהיו מוכנות בכל מכשיר ChromeOS Flex לאחר הכניסה באמצעות חשבון Google. יש לך אפשרות לבחור מה לסנכרן בהגדרות.</translation>
<translation id="5939518447894949180">איפוס</translation>
<translation id="5959471481388474538">הרשת לא זמינה</translation>
<translation id="6016178549409952427">ניווט אל תוכן נוסף <ph name="CURRENT_ELEMENT" /> מתוך <ph name="TOTAL_ELEMENTS" /></translation>
<translation id="6040143037577758943">סגירה</translation>
<translation id="6055544610007596637">‏התקנת אפליקציות ל-<ph name="DEVICE_TYPE" /> מחנות Google Play</translation>
<translation id="6071181508177083058">אישור סיסמה</translation>
<translation id="6125479973208104919">יהיה עליך להוסיף את החשבון שלך ב-<ph name="DEVICE_TYPE" /> פעם נוספת.</translation>
<translation id="6165508094623778733">למידע נוסף</translation>
<translation id="6170498031581934115">‏לא ניתן היה להפעיל ניפוי באגים באמצעות ADB. עליך לעבור להגדרות ולנסות שוב.</translation>
<translation id="6172020488605056255">כדי להשתמש בתכונה "עזרה בקריאה", לוחצים לחיצה ימנית</translation>
<translation id="6173623053897475761">יש להקליד שוב את הקוד</translation>
<translation id="6202304368170870640">קוד האימות מאפשר להיכנס למכשיר או לבטל את נעילתו.</translation>
<translation id="623261264391834964">כדי להשתמש בתכונה 'עזרה בכתיבה', צריך ללחוץ לחיצה ימנית בתיבת הטקסט</translation>
<translation id="6280215091796946657">יש להיכנס באמצעות חשבון אחר</translation>
<translation id="6287713404380454515">מטעמי אבטחה, האדמין השבית את הקוד הסודי והסיסמה של המכשיר שלך. מעכשיו צריך להשתמש בסיסמה של <ph name="MANAGER" />.</translation>
<translation id="6314819609899340042">הפעלת בהצלחה תכונות ניפוי באגים במכשיר <ph name="IDS_SHORT_PRODUCT_NAME" /> זה.</translation>
<translation id="6380143666419481200">בסדר, מקובל עליי</translation>
<translation id="6418511932144861495">התקנה של עדכון קריטי</translation>
<translation id="6480327114083866287">מנוהל על ידי <ph name="MANAGER" /></translation>
<translation id="6495266441917713704">‏לא ניתן להעביר Wi-Fi</translation>
<translation id="6515620015470298987">‏הכניסה נכשלה בגלל בעיה בבדיקת תצורת המכשיר. כדאי לבצע Powerwash במכשיר <ph name="DEVICE_TYPE" /> ולנסות שוב.</translation>
<translation id="6532527800157340614">הכניסה נכשלה כי לא ניתן היה לאחזר את טוקן הגישה שלך. יש לבדוק את החיבור לרשת ולנסות שוב.</translation>
<translation id="6607890859198268021">‏החשבון <ph name="USER_EMAIL" /> כבר מנוהל על ידי <ph name="DOMAIN" />. כדי להשתמש בבקרת הורים בחשבון Google אחר, יש לצאת לאחר ההגדרה ולבחור באפשרות "הוספת משתמש" במסך הכניסה.</translation>
<translation id="6648911618876616409">יש עדכון קריטי המוכן להתקנה. צריך להיכנס לחשבון כדי להתחיל.</translation>
<translation id="667752334740867460">‏מתקבלים פרטי Wi-Fi…</translation>
<translation id="6680442031740878064">השטח הזמין: <ph name="AVAILABLE_SPACE" /></translation>
<translation id="6722744767592605627">יש לך אפשרות לשחזר את <ph name="EMAIL" />, אבל הנתונים המקומיים יימחקו.</translation>
<translation id="6789834167207639931">‏יש להזין שוב את הסיסמה לחשבון Google במסך הבא כדי להשלים את השחזור</translation>
<translation id="6800893479155997609">האפליקציות המובילות ב-<ph name="DEVICE_TYPE" /></translation>
<translation id="6835762382653651563">יש להתחבר לאינטרנט כדי לעדכן את ה-<ph name="DEVICE_TYPE" />.</translation>
<translation id="6839916869147598086">תהליך הכניסה השתנה</translation>
<translation id="6903907808598579934">הפעלת הסנכרון</translation>
<translation id="6918733588290914545">‏הגדרה מהירה בעזרת טלפון Android</translation>
<translation id="6955698182324067397">‏הפעולה הזו מאפשרת את פעילות התכונות לניפוי באגים ב-ChromeOS שיגדירו sshd daemon ויאפשרו אתחול מכונני USB.</translation>
<translation id="6965382102122355670">אישור</translation>
<translation id="6981982820502123353">נגישות</translation>
<translation id="6984652455487792101">‏בזמן השימוש בשרת proxy צריך לבדוק את ההגדרות שלו, או
        ליצור קשר עם מנהל הרשת כדי לוודא שהשרת פועל.
        אם אין צורך להשתמש
        בו, צריך לשנות את <ph name="LINK_START" />ההגדרות לשרת proxy<ph name="LINK_END" />.</translation>
<translation id="6996245928508281884">‏עליך להפעיל את ה-Bluetooth וה-Wi-Fi בטלפון</translation>
<translation id="7077829361966535409">‏טעינת דף הכניסה באמצעות הגדרות שרת ה-proxy הנוכחיות נכשלה. <ph name="GAIA_RELOAD_LINK_START" />יש לנסות להיכנס שוב<ph name="GAIA_RELOAD_LINK_END" /> או להשתמש ב<ph name="PROXY_SETTINGS_LINK_START" />הגדרות שונות לשרת ה-proxy<ph name="PROXY_SETTINGS_LINK_END" />.</translation>
<translation id="7114054701490058191">הסיסמאות לא תואמות</translation>
<translation id="7135729336746831607">‏האם להפעיל את Bluetooth?</translation>
<translation id="7141105143012495934">הכניסה נכשלה מפני שלא ניתן היה לאחזר את פרטי החשבון. יש ליצור קשר עם מנהל המערכת או לנסות שוב.</translation>
<translation id="7144878232160441200">יש לנסות שוב</translation>
<translation id="7202337678781136582">‏צריך לסרוק את קוד ה-QR באמצעות טלפון Android</translation>
<translation id="7290242001003353852">שירות הכניסה הזה, המתארח ב-<ph name="SAML_DOMAIN" />, ניגש אל המצלמה שלך.</translation>
<translation id="7329154610228416156">הכניסה נכשלה מפני שהוגדר שימוש בכתובת אתר לא מאובטחת (<ph name="BLOCKED_URL" />). יש ליצור קשר עם מנהל המערכת.</translation>
<translation id="7345706641791090287">עליך לאשר את הסיסמה שלך</translation>
<translation id="7352651011704765696">משהו השתבש</translation>
<translation id="7476454130948140105">‏הסוללה חלשה מדי להתקנת העדכון (‎<ph name="BATTERY_PERCENT" />%‎)</translation>
<translation id="7504187084873714912">‏<ph name="BEGIN_PARAGRAPH1" />לפני ההרשמה צריך לנקות את מודול הפלטפורמה המהימנה (TPM) כדי ש-<ph name="DEVICE_OS" /> תוכל לקבל בעלות על המכשיר.<ph name="END_PARAGRAPH1" />
        <ph name="BEGIN_PARAGRAPH2" />יש לך אפשרות גם לכבות לגמרי את ה-TPM. הנתונים שלך עדיין יישמרו באופן מאובטח באמצעות הצפנת תוכנה, אבל חלק מתכונות האבטחה, כמו אישורים בגיבוי חומרה, יושבתו.<ph name="END_PARAGRAPH2" />
        <ph name="BEGIN_PARAGRAPH3" />כדי לשנות את הגדרות ה-TPM אפשר להפעיל מחדש את המכשיר ולהיכנס להגדרות ה-BIOS‏/UEFI של המערכת. השלבים משתנים בהתאם לדגם. למידע נוסף, צריך לפתוח את מאמרי העזרה בנושא <ph name="DEVICE_OS" /> במכשיר אחר לפני ההפעלה מחדש: g.co/flex/TPMHelp.<ph name="END_PARAGRAPH3" /></translation>
<translation id="7543104066686362383">יש להפעיל תכונות ניפוי באגים במכשיר <ph name="IDS_SHORT_PRODUCT_NAME" /> זה</translation>
<translation id="7553242001898162573">הזנת הסיסמה</translation>
<translation id="7556242789364317684">‏לצערנו, <ph name="SHORT_PRODUCT_NAME" /> לא יכול לשחזר את ההגדרות שלך. כדי לתקן את השגיאה, <ph name="SHORT_PRODUCT_NAME" /> צריך לאפס את המכשיר שלך באמצעות Powerwash.</translation>
<translation id="7560756177962144929">סנכרון של <ph name="DEVICE_TYPE" /></translation>
<translation id="7571643774869182231">אין מספיק שטח אחסון לעדכון</translation>
<translation id="7622114377921274169">בטעינה.</translation>
<translation id="7630426712700473382">המכשיר הזה מנוהל על ידי <ph name="MANAGER" />, וכדי להשתמש בו צריך להיכנס לחשבון בכל פעם.</translation>
<translation id="7639914187072011620">‏נכשל הניסיון לאחזר את ההפניה האוטומטית אל SAML מהשרת</translation>
<translation id="7649070708921625228">עזרה</translation>
<translation id="7658239707568436148">ביטול</translation>
<translation id="7659584679870740384">אין לך אישור להשתמש במכשיר הזה. יש ליצור קשר עם מנהל המערכת כדי לקבל הרשאה לכניסה.</translation>
<translation id="7660116474961254898">יש לפעול לפי ההוראות בטלפון</translation>
<translation id="7671139479636735732">אפשר ללחוץ לחיצה ימנית כדי להמחיש את הרעיונות שלך בקלות</translation>
<translation id="770831926727930011">הנתונים המקומיים מוגנים באמצעות הסיסמה הישנה שלך. עליך להזין את הסיסמה הישנה כדי לשחזר את הנתונים המקומיים.</translation>
<translation id="7722040605881499779">השטח שנדרש כדי לעדכן: <ph name="NECESSARY_SPACE" /></translation>
<translation id="7792012425874949788">משהו השתבש בכניסה לחשבון</translation>
<translation id="780301667611848630">לא תודה</translation>
<translation id="7803657407897251194">‏כדי להמשיך בהגדרה במכשיר Android, עליך לחבר את <ph name="DEVICE_TYPE" /> לרשת</translation>
<translation id="7851457902707056880">הכניסה הוגבלה לחשבון הבעלים בלבד. יש לבצע אתחול מחדש ולהיכנס באמצעות חשבון הבעלים. המערכת תבצע אתחול מחדש באופן אוטומטי בתוך 30 שניות.</translation>
<translation id="7870730066603611552">בדיקת אפשרויות הסינכרון אחרי ההגדרה</translation>
<translation id="7883792253546618164">בכל שלב ניתן לבטל את ההרשמה.</translation>
<translation id="7906440585529721295">הנתונים המקומיים יימחקו</translation>
<translation id="7943311690198910993">שיטת הכניסה לחשבון עודכנה</translation>
<translation id="7968982339740310781">הצגת פרטים</translation>
<translation id="7982083145464587921">כדאי לאתחל את המכשיר כדי לתקן את השגיאה.</translation>
<translation id="7990958035181555539">‏העברת ההגדרות של ה-Wi-Fi באופן אוטומטי מטלפון Android</translation>
<translation id="8054563304616131773">יש להזין כתובת אימייל חוקית</translation>
<translation id="8065144531309810062">‏שימוש ב-AI מבית Google לשיפור היצירתיות והפרודוקטיביות</translation>
<translation id="8098616321286360457">נדרש חיבור לאינטרנט</translation>
<translation id="8131740175452115882">אישור</translation>
<translation id="8146177459103116374">אם נרשמת כבר במכשיר זה, יהיה באפשרותך <ph name="LINK2_START" />להתחבר כמשתמש קיים<ph name="LINK2_END" />.</translation>
<translation id="8146793085009540321">הכניסה נכשלה. יש ליצור קשר עם מנהל המערכת או לנסות שוב.</translation>
<translation id="8202160505685531999">יש להזין שוב את הסיסמה כדי לעדכן את פרופיל <ph name="DEVICE_TYPE" />.</translation>
<translation id="8241806945692107836">קביעת תצורת המכשיר...</translation>
<translation id="8242426110754782860">המשך</translation>
<translation id="826905130698769948">אישור לקוח לא חוקי</translation>
<translation id="8274924778568117936">אין לכבות או לסגור את ה-<ph name="DEVICE_TYPE" /> לפני סיום העדכון. ה-<ph name="DEVICE_TYPE" /> יופעל מחדש באופן אוטומטי בסיום ההתקנה.</translation>
<translation id="8281886186245836920">דילוג</translation>
<translation id="8304383784961451596">‏אין לך הרשאה להשתמש במכשיר הזה. עליך לפנות למנהל המערכת לקבלת הרשאת כניסה או להיכנס באמצעות חשבון Google בפיקוח של Family Link.</translation>
<translation id="8354034204605718473">קוד האימות של הילד או הילדה נוסף</translation>
<translation id="8366396658833131068">קישוריות הרשת שלך התחדשה. יש לבחור רשת אחרת או ללחוץ על הכפתור 'המשך' שלמטה כדי להפעיל את יישום הקיוסק.</translation>
<translation id="8425768983279799676">קוד האימות מאפשר לבטל את נעילת המכשיר.</translation>
<translation id="843173223122814223">‏יצירת רקעים באמצעות AI</translation>
<translation id="8452105022015742247">‏פרטי חשבון Google מועברים מטלפון Android</translation>
<translation id="8524841856047224176">התאמה אישית של הרקעים במצלמה לשיחות וידאו ועוד</translation>
<translation id="8569673829373920831">מידע נוסף על <ph name="APP_NAME" /></translation>
<translation id="8628232294964836490">‏כדי לסרוק את קוד ה-QR, צריך לפעול לפי ההוראות בטלפון. חשוב לוודא שה-Bluetooth בטלפון מופעל.
        <ph name="BR" />
        <ph name="BR" />
        גלוי למכשירים בקרבת מקום בתור <ph name="QUICK_START_DEVICE_DISPLAY_NAME" />...</translation>
<translation id="8655972064210167941">הכניסה נכשלה מפני שלא ניתן היה לאמת את הסיסמה. יש לפנות למנהל המערכת או לנסות שוב.</translation>
<translation id="8674903726754070732">‏לצערנו, המחשב שלך מוגדר באמצעות מזהה חומרה פגום. המצב הזה מונע מ-ChromeOS להתקין את עדכוני האבטחה האחרונים, <ph name="BEGIN_BOLD" />ויכול להיות שהמחשב שלך יהיה חשוף להתקפות זדוניות<ph name="END_BOLD" />.</translation>
<translation id="8695139659682234808">הוספה של בקרת הורים לאחר ההגדרה</translation>
<translation id="8725066075913043281">ניסיון חוזר</translation>
<translation id="8730621377337864115">בוצע</translation>
<translation id="8740086188450289493">‏שימוש בסיסמה לחשבון Google</translation>
<translation id="8740247629089392745">‏אפשר להעביר את ה-Chromebook הזה אל <ph name="SUPERVISED_USER_NAME" />. ההתקנה כמעט הסתיימה. מיד ניתן יהיה לחקור ולהתנסות.</translation>
<translation id="8759753423332885148">למידע נוסף</translation>
<translation id="8777628254805677039">‏סיסמת root</translation>
<translation id="8794548468611058947">‏במקום להזין את הסיסמה לחשבון Google כדי להיכנס, אפשר ליצור קוד אימות למכשיר <ph name="DEVICE_TYPE" /> הזה</translation>
<translation id="8830796635868321089">‏בדיקת העדכון נכשלה עם ההגדרות הנוכחיות של שרת ה-proxy‏. יש להתאים את <ph name="PROXY_SETTINGS_LINK_START" />הגדרות שרת ה-proxy שלך<ph name="PROXY_SETTINGS_LINK_END" />.</translation>
<translation id="885746075120788020">‏הפעילות וההעדפות השמורות שלך יהיו מוכנות בכל מכשיר ChromeOS לאחר הכניסה באמצעות חשבון Google. יש לך אפשרות לבחור מה לסנכרן בהגדרות.</translation>
<translation id="8875221558267407626">מסכמים תכנים, מפשטים שפה מורכבת או שואלים שאלות</translation>
<translation id="8913163265790894442">‏קל להגדיר את ה-<ph name="DEVICE_TYPE" /> באמצעות הטלפון. אפשר להוסיף את ה-Wi-Fi ואת החשבון שלך ב-Google, גם בלי להקליד את הסיסמאות.
        <ph name="BR" />
        <ph name="BR" />
        גלוי בתור <ph name="DEVICE_TYPE" />...</translation>
<translation id="8946359700442089734">תכונות לניפוי באגים לא הופעלו באופן מלא במכשיר <ph name="IDS_SHORT_PRODUCT_NAME" /> זה.</translation>
<translation id="8965037249707889821">יש להזין את הסיסמה הישנה</translation>
<translation id="8975396729541388937">ניתן לבטל את ההרשמה בכל שלב בלחיצה על הקישור בהודעות האימייל שמקבלים.</translation>
<translation id="9033765790910064284">אני רוצה להמשיך בכל זאת</translation>
<translation id="903480517321259405">יש להקליד שוב את קוד האימות</translation>
<translation id="9076523132036239772">מצטערים, לא ניתן לאמת את האימייל או הסיסמה שלך. יש לנסות תחילה להתחבר לרשת.</translation>
<translation id="9217002308921247002">‏<ph name="BEGIN_PARAGRAPH1" />בלעדי ל-<ph name="DEVICE_TYPE" />.<ph name="END_PARAGRAPH1" />
        <ph name="BEGIN_PARAGRAPH2" />ה-AI הגנרטיבי הוא ניסיוני, ונמצא בשלבי פיתוח ראשוניים. כרגע הזמינות שלו מוגבלת.<ph name="END_PARAGRAPH2" /></translation>
<translation id="936479314588646618">‏קל להגדיר את ה-<ph name="DEVICE_TYPE" /> באמצעות הטלפון. עליך פשוט להוסיף את החשבון שלך ב-Google, אפילו בלי להקליד את הסיסמה.
        <ph name="BR" />
        <ph name="BR" />
        גלוי בתור <ph name="DEVICE_TYPE" />...</translation>
</translationbundle>