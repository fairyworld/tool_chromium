<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="te">
<translation id="1005333234656240382">ADB డీబగ్గింగ్‌ను ఎనేబుల్ చేయాలా?</translation>
<translation id="1076766328672150609">డివైజ్‌ను అన్‌లాక్ చేయడానికి మీ చిన్నారి PINను ఉపయోగించవచ్చు.</translation>
<translation id="1097658378307015415">సైన్ ఇన్ చేయడానికి ముందుగా, దయచేసి <ph name="NETWORK_ID" /> నెట్‌వర్క్‌ను యాక్టివేట్ చేయడానికి గెస్ట్ లాగా ప్రవేశించండి</translation>
<translation id="1111932478203988717">మీ చిన్నారి తమ పరికరానికి సైన్ ఇన్ చేయడానికి ఈ PINను ఉపయోగించవచ్చు</translation>
<translation id="1122587596907914265">ప్రత్యేకమైన వాల్‌పేపర్‌లను రూపొందించుకోండి</translation>
<translation id="1131201598497838573">మీ చిన్నారి PIN అప్‌డేట్ చేయబడింది</translation>
<translation id="1147322039136785890">ఇప్పుడు దీనిని <ph name="SUPERVISED_USER_NAME" /> ఉపయోగించవచ్చు</translation>
<translation id="1176864681932214421">AI సహాయంతో ఇమేజ్‌లను క్రియేట్ చేయండి</translation>
<translation id="1177073277575830464">Android త్వరిత సెటప్ పూర్తయింది. మీ <ph name="DEVICE_TYPE" />లో సెటప్ చేయడాన్ని కొనసాగించండి.</translation>
<translation id="1179902906564467236">మీ ఫోన్‌లోని సూచనలను ఫాలో అవ్వండి లేదా కెమెరా యాప్‌ను ఉపయోగించండి</translation>
<translation id="1185924365081634987">మీరు ఈ నెట్‌వర్క్ ఎర్ర‌ర్‌ను పరిష్కరించడానికి <ph name="GUEST_SIGNIN_LINK_START" />అతిథిగా బ్రౌజ్ చేయడాన్ని<ph name="GUEST_SIGNIN_LINK_END" /> కూడా ప్రయత్నించవచ్చు.</translation>
<translation id="1201402288615127009">తర్వాత</translation>
<translation id="1222835797152767346">సైన్ ఇన్ చేయడాన్ని సులభతరం చేయడానికి పాస్‌వర్డ్‌ను సెట్ చేయండి</translation>
<translation id="1346669614038013595"><ph name="BEGIN_H3" />డీబగ్గింగ్ ఫీచర్‌లు<ph name="END_H3" />
      <ph name="BR" />
      మీరు మీ డివైజ్‌లో అనుకూల కోడ్‌ను ఇన్‌స్టాల్ చేసి, టెస్ట్ చేయడానికి మీ ChromeOS డివైజ్‌లో డీబగ్గింగ్ ఫీచర్‌లను ఎనేబుల్ చేయవచ్చు. ఇది వీటిని చేయడానికి మిమ్మల్ని అనుమతిస్తుంది:<ph name="BR" />
      <ph name="BEGIN_LIST" />
        <ph name="LIST_ITEM" />rootfs వెరిఫికేషన్‌ను తీసివేయడానికి, తద్వారా మీరు OS ఫైల్స్‌ను మాడిఫై చేయవచ్చు
        <ph name="LIST_ITEM" />స్టాండర్డ్ టెస్ట్ 'కీ'లను ఉపయోగించి డివైజ్‌కు SSH యాక్సెస్‌ను ఎనేబుల్ చేయడానికి, తద్వారా మీరు డివైజ్‌ను యాక్సెస్ చేయడానికి <ph name="BEGIN_CODE" />'cros flash'<ph name="END_CODE" /> వంటి టూల్స్‌ను ఉపయోగించవచ్చు
        <ph name="LIST_ITEM" />USB నుండి బూట్ చేయడాన్ని ఎనేబుల్ చేయడానికి, తద్వారా మీరు USB డ్రైవర్ నుండి OS ఇమేజ్‌ను ఇన్‌స్టాల్ చేయవచ్చు
        <ph name="LIST_ITEM" />డెవలపర్ అలాగే సిస్టమ్ రూట్ లాగిన్ పాస్‌వర్డ్ రెండింటినీ అనుకూల విలువకు సెట్ చేయడానికి, తద్వారా మీరు డివైజ్‌లోకి మాన్యువల్‌గా SSH చేయవచ్చు
      <ph name="END_LIST" />
      <ph name="BR" />
      ఎనేబుల్ చేసిన తర్వాత, ఎంటర్‌ప్రయిజ్ ద్వారా మేనేజ్ అయ్యే డివైజ్‌లో డేటాను పవర్‌వాష్ చేసిన తర్వాత లేదా పూర్తిగా తొలగించిన తర్వాత కూడా చాలా వరకు డీబగ్గింగ్ ఫీచర్‌లు ఎనేబుల్ అయ్యి ఉంటాయి. అన్ని డీబగ్గింగ్ ఫీచర్‌లను పూర్తిగా డిజేబుల్ చేయడానికి, ChromeOS రికవరీ ప్రాసెస్‌ను పూర్తి చేయండి (https://support.google.com/chromebook/answer/1080595).
      <ph name="BR" />
      <ph name="BR" />
      డీబగ్గింగ్ ఫీచర్‌ల గురించి మరింత సమాచారం కోసం ఇక్కడ చూడండి:<ph name="BR" />
      https://www.chromium.org/chromium-os/how-tos-and-troubleshooting/debugging-features
      <ph name="BR" />
      <ph name="BR" />
      <ph name="BEGIN_BOLD" />గమనిక:<ph name="END_BOLD" />  ప్రాసెస్ సమయంలో సిస్టమ్ రీబూట్ అవుతుంది.</translation>
<translation id="1347625331607114917">మీ Android ఫోన్‌లో కోడ్‌ను వెరిఫై చేయండి</translation>
<translation id="1347975661240122359">బ్యాటరీ <ph name="BATTERY_LEVEL" />% ఉన్నప్పుడు అప్‌డేట్ ప్రారంభమవుతుంది.</translation>
<translation id="1375938286942050085">సెటప్ పూర్తయింది! తర్వాత, వీడియో గేమ్‌ల కోసం మీ డివైజ్‌ను సిద్ధం చేయండి</translation>
<translation id="1377600615067678409">ప్రస్తుతానికి దాటవేయి</translation>
<translation id="1400243387594338234">మీ పరికరానికి సైన్ ఇన్ చేయడానికి మీరు ఈ PINను ఉపయోగించవచ్చు</translation>
<translation id="1426410128494586442">అవును</translation>
<translation id="1473927070149284123">మళ్లీ ట్రై చేయండి లేదా మాన్యువల్‌గా నెట్‌వర్క్‌కు కనెక్ట్ చేయండి</translation>
<translation id="1503556098270577657">మీరు మీ Android ఫోన్‌ను ఉపయోగించి <ph name="USER_EMAIL" />కి సైన్ ఇన్ చేశారు</translation>
<translation id="1521442365706402292">సర్టిఫికెట్‌లను మేనేజ్ చేయండి</translation>
<translation id="1572876035008611720">మీ ఈమెయిల్‌ను నమోదు చేయండి</translation>
<translation id="1642494467033190216">ఇతర డీబగ్గింగ్ ఫీచ‌ర్‌లను ప్రారంభించడానికి ముందు rootfs రక్షణను తీసివేసి, పునఃప్రారంభించాలి.</translation>
<translation id="1678919064276516737">మీరు ఎంటర్ చేసిన ఈమెయిల్, PIN మ్యాచ్ అవ్వడం లేదు</translation>
<translation id="169675691788639886">పరికరానికి SSH సర్వర్ కాన్ఫిగ‌ర్ చేయబడింది. గోప్యమైన ఖాతాలతో సైన్ ఇన్ చేయవద్దు.</translation>
<translation id="1730666151302379551">పాత పాస్‌వర్డ్‌ను మర్చిపోయారా</translation>
<translation id="1826192255355608658">మీ Chrome బ్రౌజర్ బుక్‌మార్క్‌లు, పాస్‌వర్డ్‌‌లు, హిస్టరీ, ఇంకా మరిన్నింటిని సింక్ చేయండి</translation>
<translation id="1831848493690504725">కనెక్ట్ చేయబడిన నెట్‌వర్క్ ద్వారా Googleను చేరుకోవడం మాకు సాధ్యపడలేదు. వేరే నెట్‌వర్క్‌ను ఎంచుకోవడానికి ట్రై చేయండి లేదా మీ నెట్‌వర్క్ సెట్టింగ్‌లను లేదా ప్రాక్సీ సెట్టింగ్‌లను (మీరు ప్రాక్సీని ఉపయోగిస్తున్నట్లయితే) చెక్ చేయడానికి ట్రై చేయండి.</translation>
<translation id="1987574314042117472">జనాదరణ పొందిన యాప్‌లను ఎంచుకుని, ఇన్‌స్టాల్ చేయండి</translation>
<translation id="2052572566310583903">మీ ఇతర పరికరాలలో ఇన్‌స్టాల్ చేయబడింది</translation>
<translation id="2090165459409185032">మీ ఖాతా సమాచారాన్ని పునరుద్ధరించడానికి, దీనికి వెళ్లండి: google.com/accounts/recovery</translation>
<translation id="2157779167749714207">మీ <ph name="DEVICE_TYPE" />‌తో పాటు Gemini వస్తుంది</translation>
<translation id="2163470535490402084">మీ <ph name="DEVICE_TYPE" />కు సైన్ ఇన్ చేయడానికి దయచేసి ఇంటర్నెట్‌కు కనెక్ట్ చేయండి.</translation>
<translation id="2178585470774851578">మీరు ChromeOS Flex డీబగ్గింగ్ ఫీచర్‌లను ఎనేబుల్ చేస్తున్నారు, ఇది sshd daemonను సెటప్ చేస్తుంది అలాగే USB డిస్క్‌ల నుండి బూట్ చేయడాన్ని ఎనేబుల్ చేస్తుంది.</translation>
<translation id="2219081237089444028">సైన్ ఇన్ చేయడాన్ని సులభతరం చేయడానికి <ph name="DEVICE_TYPE" /> పాస్‌వర్డ్‌ను సెట్ చేయండి</translation>
<translation id="2296022312651137376"><ph name="DOMAIN_NAME" />కి <ph name="EMAIL" />కు సైన్ ఇన్ చేసేటప్పుడు పరికరం ఆన్‌లో ఉండాలి</translation>
<translation id="2317842250900878657"><ph name="PROGRESS_PERCENT" />% పూర్తయింది</translation>
<translation id="2319072477089403627">మీ Android ఫోన్‌కు కనెక్ట్ అవుతోంది...</translation>
<translation id="2328137272841210255">మీ PINను రీసెట్ చేయండి</translation>
<translation id="2342180549977909852">ఈ డివైజ్‌ను అన్‌లాక్ చేయడానికి మీ చిన్నారి పాస్‌వర్డ్‌కు బదులుగా నంబర్ (PIN)ను ఉపయోగించవచ్చు. PINను సెట్ చేయడానికి, సెట్టింగ్‌లకు వెళ్లండి.</translation>
<translation id="2359808026110333948">కొనసాగించండి</translation>
<translation id="2408955596600435184">మీ PINని నమోదు చేయండి</translation>
<translation id="2439152382014731627"><ph name="DEVICE_TYPE" /> పాస్‌వర్డ్‌ను రీసెట్ చేయండి</translation>
<translation id="2450223707519584812">Google API కీలు లేనందున మీరు వినియోగదారులను జోడించలేరు. వివరాల కోసం <ph name="DETAILS_URL" /> చూడండి.</translation>
<translation id="2582253231918033891"><ph name="PRODUCT_NAME" /> <ph name="PRODUCT_VERSION" /> (ప్లాట్‌ఫారమ్ <ph name="PLATFORM_VERSION" />) <ph name="DEVICE_SERIAL_NUMBER" /></translation>
<translation id="2725200716980197196">నెట్‌వర్క్ కనెక్టివిటీ పునరుద్ధరించబడింది</translation>
<translation id="2731700343119398978">దయచేసి వేచి ఉండండి...</translation>
<translation id="2732134891301408122"><ph name="TOTAL_ELEMENTS" />లో <ph name="CURRENT_ELEMENT" />వ అదనపు కంటెంట్</translation>
<translation id="2740531572673183784">సరే</translation>
<translation id="2754825024506485820">పని చేసే సామర్థ్యాన్ని పెంచడం దగ్గర నుండి వినోదం దాకా మీకు అవసరమైన యాప్‌లను Google Play Storeలో కనుగొనండి. యాప్‌లను మీరు ఎప్పుడైనా ఇన్‌స్టాల్ చేయవచ్చు.</translation>
<translation id="2805539617243680210">మీరు మొత్తం పూర్తి చేశారు!</translation>
<translation id="2832124733806557606">మీ చిన్నారి, పరికరానికి సైన్ ఇన్ చేయడానికి లేదా అన్‌లాక్ చేయడానికి PINను ఉపయోగించవచ్చు.</translation>
<translation id="283669119850230892"><ph name="NETWORK_ID" /> నెట్‌వర్క్‌ను ఉపయోగించడానికి, మొదట దిగువ ఇంటర్నెట్‌కు మీ కనెక్షన్‌ను పూర్తి చేయండి.</translation>
<translation id="2849767214114481738">మీ PINను జోడించడం జరిగింది</translation>
<translation id="2893180576842394309">శోధన, ఇతర Google సేవలను వ్యక్తిగతీకరించడానికి Google మీ హిస్టరీని ఉపయోగించే అవకాశం ఉంటుంది</translation>
<translation id="2904210161403910217">చివరిసారి సైన్ ఇన్ చేసిన తర్వాత మీ పాస్‌వర్డ్ మార్చబడింది</translation>
<translation id="2921081876747860777">దయచేసి మీ స్థానిక డేటాను రక్షించడానికి పాస్‌వర్డ్‌ను క్రియేట్ చేయండి.</translation>
<translation id="2950666755714083615">నన్ను సైన్ అప్ చేయనివ్వు</translation>
<translation id="2979966855249721010">మీ ఆసక్తుల ఆధారంగా, మీరు యాప్ సిఫార్సులు, చిట్కాలు, మరిన్నింటిని చూడవచ్చు</translation>
<translation id="3012917896646559015">మీ కంప్యూటర్‌ను మరమ్మత్తు చేయడానికి పంపడానికి, దయచేసి వెంటనే మీ హార్డ్‌వేర్ తయారీదారుని సంప్రదించండి.</translation>
<translation id="3028371505549235127">సైన్ ఇన్ చేయడానికి మీ Google ఖాతా పాస్‌వర్డ్‌ను ఎంటర్ చేయడానికి బదులుగా, మీరు ఈ పరికరం కోసం <ph name="DEVICE_TYPE" /> పాస్‌వర్డ్‌ను క్రియేట్ చేయవచ్చు</translation>
<translation id="3101924772906986970">మీ Chrome బ్రౌజర్ బుక్‌మార్క్‌లు, పాస్‌వర్డ్‌లు, హిస్టరీ, ఇంకా మరిన్ని వివరాలు మీ Google ఖాతాలో సేవ్ అవుతాయి</translation>
<translation id="313205617302240621">పాస్‌వర్డ్‌ను మర్చిపోయారా?</translation>
<translation id="3170072451822350649">మీరు సైన్ ఇన్ చేయడాన్ని కూడా దాట వేయవచ్చు. <ph name="LINK_START" />అతిథిగా బ్రౌజ్ చేయవచ్చు<ph name="LINK_END" />.</translation>
<translation id="3196912927885212665">మీ Android ఫోన్‌తో సెటప్ చేయడానికి, మీ Chromebook బ్లూటూత్ ఆన్‌లో ఉండాలి</translation>
<translation id="3238192140106069382">కనెక్ట్ చేయడానికి మరియు వెరిఫై చేయడానికి ట్రై చేస్తోంది</translation>
<translation id="3261268979727295785">ఎదిగిన పిల్లల కోసం, మీరు సెటప్‌ను పూర్తి చేశాక తల్లిదండ్రుల నియంత్రణలను జోడించవచ్చు. తల్లిదండ్రుల నియంత్రణలకు సంబంధించిన సమాచారాన్ని Explore యాప్‌లో చూడగలరు.</translation>
<translation id="3278001907972365362">మీ Google ఖాతా లేదా ఖాతాలను జాగ్రత్తగా గమనించాలి</translation>
<translation id="3283148363895519428">మీ ఫోన్‌లోని సూచనలను ఫాలో అయ్యి, సెటప్‌ను కొనసాగించండి. మీ ఫోన్ సమీపంలో ఉందని, బ్లూటూత్ ఆన్ చేసి ఉందని నిర్ధారించుకోండి.</translation>
<translation id="3435896845095436175">ప్రారంభించండి</translation>
<translation id="3462413494201477527">ఖాతా సెటప్‌ను రద్దు చేయాలా?</translation>
<translation id="3473241910002674503">టాబ్లెట్ మోడ్‌లో బటన్‌లతో హోమ్, వెనుకకు, స్విచ్ యాప్‌లను నావిగేట్ చేయండి.</translation>
<translation id="3491669675709357988">Family Link తల్లిదండ్రుల నియంత్రణల కోసం మీ చిన్నారి ఖాతా సెటప్ చేయబడలేదు. మీరు ఒకసారి సెటప్‌ను పూర్తి చేసిన తర్వాత, తల్లిదండ్రుల నియంత్రణలను జోడించగలరు. తల్లిదండ్రుల నియంత్రణలకు సంబంధించిన సమాచారాన్ని Explore యాప్‌లో చూడగలరు.</translation>
<translation id="3635199270495525546">ట్రస్టెడ్ ప్లాట్‌ఫారమ్ మాడ్యూల్ (TPM) గుర్తించబడింది</translation>
<translation id="3661106764436337772">మరింత వేగంగా, మరింత నమ్మకంతో రాయండి</translation>
<translation id="3662207097851752847">మీ ఫోన్‌లో మీ Google ఖాతాను నిర్ధారించండి</translation>
<translation id="3672681487849735243">ఫ్యాక్టరీ ఎర్రర్ గుర్తించబడింది</translation>
<translation id="3673097791729989571">సైన్ ఇన్‌ను <ph name="SAML_DOMAIN" /> హోస్ట్ చేసింది</translation>
<translation id="3673287357837016374">మీ PIN అప్‌డేట్ చేయబడింది</translation>
<translation id="367645871420407123">మీరు రూట్ పాస్‌వర్డ్‌ను డిఫాల్ట్ పరీక్ష చిత్ర విలువకు సెట్ చేయాలనుకుంటే ఖాళీగా వదిలిపెట్టండి</translation>
<translation id="3712050472459130149">ఖాతాను అప్‌డేట్ చేయడం అవసరం</translation>
<translation id="3733296813637058299">మేము మీ కోసం ఆ యాప్‌లు ఇన్‌స్టాల్ చేస్తాము. మీరు Play Storeలో మీ <ph name="DEVICE_TYPE" /> కోసం మరిన్ని యాప్‌లను కనుగొనవచ్చు.</translation>
<translation id="376841534249795524">మీ <ph name="DEVICE_TYPE" /> డివైజ్‌ను మీరు దేని కోసం ఉపయోగిస్తారు?</translation>
<translation id="3789841737615482174">ఇన్‌స్టాల్ చేయండి</translation>
<translation id="385051799172605136">వెనుకకు</translation>
<translation id="3897746662269329507">మీ <ph name="DEVICE_TYPE" />, వీడియో గేమ్‌ల కోసం బిల్డ్ చేయబడింది. తర్వాత, 'అన్వేషణ' యాప్ తెరవబడుతుంది, అందులో మీరు వందల కొద్దీ తాజా గేమ్‌లను యాక్సెస్ చేయవచ్చు, వీడియో గేమ్‌ల ఆఫర్‌లను చూడవచ్చు, మీ పరికరంతో వచ్చే వీడియో గేమ్ ఫీచర్‌ల గురించి తెలుసుకోవచ్చు.</translation>
<translation id="3910588685973519483">AIతో వాల్‌పేపర్‌లను క్రియేట్ చేయండి</translation>
<translation id="3950820424414687140">సైన్ ఇన్</translation>
<translation id="3994318741694670028">దురదృష్టవశాత్తూ, తప్పుగా ఫార్మాట్ చేయబడిన హార్డ్‌వేర్ IDతో మీ కంప్యూటర్ కాన్ఫిగర్ చేయబడింది. ఇది సెక్యూరిటీ పరిష్కారాలతో అప్‌డేట్ కాకుండా ChromeOS Flexను నిరోధిస్తుంది, అలాగే మీ కంప్యూటర్ <ph name="BEGIN_BOLD" />హానికరమైన దాడులకు గురి కావచ్చు<ph name="END_BOLD" />.</translation>
<translation id="4002440992267487163">పిన్ సెటప్</translation>
<translation id="4044883420905480380">మీరు Wi-Fiకి కనెక్ట్ చేసి, మీ Android ఫోన్‌ను ఉపయోగించి <ph name="USER_EMAIL" />‌కు సైన్ ఇన్ చేశారు</translation>
<translation id="4062561150282203854">మీ <ph name="DEVICE_TYPE" /> యాప్‌లు, సెట్టింగ్‌లు, ఇంకా మరిన్నింటిని సింక్ చేయండి</translation>
<translation id="4089743381329341712">సెటప్ చేసిన తర్వాత ఎంచుకున్న యాప్‌లు ఇన్‌స్టాల్ అవుతాయి. యాప్‌లు &amp; గేమ్‌ల యాప్‌లో తర్వాత మరిన్ని సిఫార్సులను కనుగొనండి.</translation>
<translation id="4104944259562794668">మీరు దానిని తర్వాత సెట్టింగ్‌లు &gt; సెక్యూరిటీ, గోప్యత &gt; లాక్ స్క్రీన్, సైన్ ఇన్ అనే ఆప్షన్‌లో ఎనేబుల్ చేయవచ్చు</translation>
<translation id="41365691917097717">దీనిని కొనసాగించడం వలన Android యాప్‌లను రూపొందించడానికి, పరీక్షించడానికి ADB డీబగ్గింగ్ ఎనేబుల్ అవుతుంది. ఈ చర్య వలన Google ద్వారా ధృవీకరించబడని Android యాప్‌ల ఇన్‌స్టాలేషన్ అనుమతించబడుతుందని, దీనిని డిజేబుల్ చేయడానికి ఫ్యాక్టరీ రీసెట్ చేయాల్సి ఉంటుందని గుర్తుంచుకోండి.</translation>
<translation id="4232484478444192782">మీ Android ఫోన్ మీకు సహాయం చేస్తుంది. మీ WiFi, పాస్‌వర్డ్ బదిలీ అవుతున్నాయి.</translation>
<translation id="4242145785130247982">బహుళ క్లయింట్ సర్టిఫికెట్‌లకు మద్దతు లేదు</translation>
<translation id="4250680216510889253">లేదు</translation>
<translation id="4263223596040212967">మీ కీబోర్డ్ లేఅవుట్‌ను చెక్ చేసి, మళ్లీ ట్రై చేయండి.</translation>
<translation id="4289732974614035569">PINను ఎంచుకోండి</translation>
<translation id="4317733381297736564">యాప్‌లో కొనుగోళ్లు</translation>
<translation id="4370975561335139969">మీరు నమోదు చేసిన ఈమెయిల్‌, పాస్‌వర్డ్ సరిపోలలేదు</translation>
<translation id="4373418556073552953">మీ Android ఫోన్‌తో సైన్ ఇన్ చేయండి</translation>
<translation id="4410545552906060960">మీ డివైజ్‌ను అన్‌లాక్ చేయడానికి పాస్‌వర్డ్‌‌కు బదులుగా నంబర్ (PIN)ను ఉపయోగించండి. తర్వాత మీ PINను సెట్ చేయడానికి, సెట్టింగ్‌లకు వెళ్లండి.</translation>
<translation id="4415213869328311284">మీ <ph name="DEVICE_TYPE" />ను ఉపయోగించడం ప్రారంభించడానికి మీరు సిద్ధంగా ఉన్నారు.</translation>
<translation id="4450974146388585462">విశ్లేషించు</translation>
<translation id="445099924538929605">మీ డేటాను మరింత సురక్షితంగా స్టోర్ చేయగల ఒక యాక్టివ్ TPMను <ph name="DEVICE_OS" /> గుర్తించింది.</translation>
<translation id="4472575034687746823">ప్రారంభించండి</translation>
<translation id="4567512141633030272">సైన్ ఇన్ ఆప్షన్ తప్పుగా ఉందా?</translation>
<translation id="4568213207643490790">క్షమించండి, ఈ పరికరంలో Google ఖాతాలకు అనుమతి లేదు.</translation>
<translation id="4611759022973144129">మీ <ph name="DEVICE_TYPE" />కి సైన్ ఇన్ చేయడానికి మీరు ఈ పాస్‌వర్డ్‌ను ఉపయోగించవచ్చు.</translation>
<translation id="4727847987444062305">నిర్వాహిత గెస్ట్ సెషన్</translation>
<translation id="473775607612524610">అప్‌డేట్‌</translation>
<translation id="473936925429402449"><ph name="TOTAL_ELEMENTS" />లో <ph name="CURRENT_ELEMENT" />వ అదనపు కంటెంట్ ఎంచుకోబడింది</translation>
<translation id="4830502475412647084">OS అప్‌డేట్‌ ఇన్‌స్టాల్ చేయబడుతుంది</translation>
<translation id="4837926214103741331">ఈ డివైజ్‌ను ఉపయోగించడానికి మీకు అధికారం లేదు. దయచేసి సైన్-ఇన్ అనుమతి కోసం డివైజ్ ఓనర్‌ను కాంటాక్ట్ చేయండి.</translation>
<translation id="4864369630010738180">సైన్ ఇన్ అవుతోంది...</translation>
<translation id="4899696330053002588">యాడ్‌లను కలిగి ఉంది</translation>
<translation id="4944310289250773232">ఈ ప్రమాణీకరణ సేవ <ph name="SAML_DOMAIN" /> ద్వారా హోస్ట్ చేయబడుతోంది</translation>
<translation id="4955710816792587366">మీ పిన్ ఎంచుకోండి</translation>
<translation id="5029287942302939687">మీ పాస్‌వర్డ్ సెట్ చేయబడింది</translation>
<translation id="503155457707535043">యాప్‌లు డౌన్‌లోడ్ చేయబడుతున్నాయి</translation>
<translation id="5045550434625856497">సరికాని పాస్‌వర్డ్</translation>
<translation id="5062930723426326933">సైన్-ఇన్ విఫలమైంది, దయచేసి ఇంటర్నెట్‌కు కనెక్ట్ చేసి మళ్లీ ట్రై చేయండి.</translation>
<translation id="5107486920067578245"><ph name="BEGIN_PARAGRAPH1" />Google AIతో రాయడం, ప్లాన్ చేయడం, నేర్చుకోవడం, ఇంకా మరెన్నో చేయడానికి Geminiతో చాట్ చేయండి.<ph name="END_PARAGRAPH1" />
        <ph name="BEGIN_PARAGRAPH2" />సెటప్ చేసిన తర్వాత, Geminiని ఉపయోగించడం ప్రారంభించడానికి మీ షెల్ఫ్‌లో స్క్రీన్ దిగువున ఉన్న Gemini యాప్‌ను ఎంచుకోండి.<ph name="END_PARAGRAPH2" /></translation>
<translation id="5115309401544567011">దయచేసి మీ <ph name="DEVICE_TYPE" />ని ఛార్జింగ్ పెట్టండి</translation>
<translation id="5147516217412920887">మీ ఫోన్‌లోని సూచనలను ఫాలో అయ్యి, కోడ్‌ను వెరిఫై చేయండి</translation>
<translation id="5160857336552977725">మీ <ph name="DEVICE_TYPE" />కు సైన్ ఇన్ చేయండి</translation>
<translation id="5171185788583376591"><ph name="BEGIN_H3" />డీబగ్గింగ్ ఫీచర్‌లు<ph name="END_H3" />
      <ph name="BR" />
      మీరు మీ డివైజ్‌లో అనుకూల కోడ్‌ను ఇన్‌స్టాల్ చేసి టెస్ట్ చేయడానికి, మీ ChromeOS Flex డివైజ్‌లో డీబగ్గింగ్ ఫీచర్‌లను ఎనేబుల్ చేయవచ్చు.  ఇది వీటిని చేయడానికి మిమ్మల్ని అనుమతిస్తుంది:<ph name="BR" />
      <ph name="BEGIN_LIST" />
        <ph name="LIST_ITEM" />rootfs వెరిఫికేషన్‌ను తీసివేయడానికి; తద్వారా మీరు OS ఫైల్స్‌ను మాడిఫై చేయవచ్చు
        <ph name="LIST_ITEM" />స్టాండర్డ్ టెస్ట్ 'కీ'లను ఉపయోగించి డివైజ్‌కు SSH యాక్సెస్‌ను ఎనేబుల్ చేయడానికి; తద్వారా మీరు డివైజ్‌ను యాక్సెస్ చేయడానికి <ph name="BEGIN_CODE" />'cros flash'<ph name="END_CODE" /> వంటి టూల్స్‌ను ఉపయోగించవచ్చు
        <ph name="LIST_ITEM" />USB నుండి బూట్ చేయడాన్ని ఎనేబుల్ చేయడానికి; తద్వారా మీరు USB డ్రైవర్ నుండి OS ఇమేజ్‌ను ఇన్‌స్టాల్ చేయవచ్చు
        <ph name="LIST_ITEM" />డెవలపర్ అలాగే సిస్టమ్ రూట్ లాగిన్, పాస్‌వర్డ్, రెండింటినీ అనుకూల విలువకు సెట్ చేయడానికి; తద్వారా మీరు డివైజ్‌లోకి మాన్యువల్‌గా SSH చేయవచ్చు
      <ph name="END_LIST" />
      <ph name="BR" />
      ఎనేబుల్ చేసిన తర్వాత, ఎంటర్‌ప్రయిజ్ ద్వారా మేనేజ్ అయ్యే డివైజ్‌లో డేటాను పవర్‌వాష్ చేసిన తర్వాత లేదా పూర్తిగా తొలగించిన తర్వాత కూడా చాలా వరకు డీబగ్గింగ్ ఫీచర్‌లు ఎనేబుల్ అయ్యి ఉంటాయి. అన్ని డీబగ్గింగ్ ఫీచర్‌లను పూర్తిగా డిజేబుల్ చేయడానికి, ChromeOS రికవరీ ప్రాసెస్‌ను పూర్తి చేయండి (https://support.google.com/chromebook/answer/1080595).
      <ph name="BR" />
      <ph name="BR" />
      డీబగ్గింగ్ ఫీచర్‌ల గురించి మరింత సమాచారం కోసం ఈ పేజీకి వెళ్లండి:<ph name="BR" />
      https://www.chromium.org/chromium-os/how-tos-and-troubleshooting/debugging-features
      <ph name="BR" />
      <ph name="BR" />
      <ph name="BEGIN_BOLD" />గమనిక:<ph name="END_BOLD" />  ప్రాసెస్ సమయంలో సిస్టమ్ రీబూట్ అవుతుంది.</translation>
<translation id="523505283826916779">యాక్సెస్‌ సెట్టింగ్‌లు</translation>
<translation id="5240931875940563122">Android ఫోన్‌తో సైన్ ఇన్ చేయండి</translation>
<translation id="5255859108402770436">మళ్లీ సైన్ ఇన్ చేయండి</translation>
<translation id="5260508466980570042">క్షమించండి, మీ ఈమెయిల్‌ లేదా పాస్‌వర్డ్ ధృవీకరించబడలేదు. దయచేసి మళ్ళీ ప్రయత్నించండి.</translation>
<translation id="5264252276333215551">మీ యాప్‌ను కియోస్క్ మోడ్‌లో ప్రారంభించడానికి దయచేసి ఇంటర్నెట్‌కు కనెక్ట్ చేయండి.</translation>
<translation id="528208740344463258">Android యాప్‌లను డౌన్‌లోడ్ చేసి, ఉపయోగించడం కోసం, ముందుగా మీరు ఈ అవసరమైన అప్‌డేట్‌ను ఇన్‌స్టాల్ చేయాలి. మీ <ph name="DEVICE_TYPE" /> అప్‌డేట్ అవుతున్న సమయంలో, మీరు దీనిని ఉపయోగించలేరు. ఇన్‌స్టాల్ చేయడం పూర్తయిన తర్వాత, మీ <ph name="DEVICE_TYPE" /> పునఃప్రారంభించబడుతుంది.</translation>
<translation id="542948651837270806">విశ్వసనీయ ప్లాట్‌ఫామ్ మాడ్యూల్ ఫర్మ్‌వేర్ కోసం అప్‌డేట్‌ను ఇన్‌స్టాల్ చేయాలి. <ph name="TPM_FIRMWARE_UPDATE_LINK" />ను చూడండి</translation>
<translation id="5448293924669608770">అయ్యో, సైన్ ఇన్ చేయడంలో ఏదో తప్పు జరిగింది</translation>
<translation id="5463450804024056231"><ph name="DEVICE_TYPE" /> ఈమెయిల్స్ కోసం సైన్ అప్ చేయండి</translation>
<translation id="5527474464531963247">మీరు మరొక నెట్‌వర్క్‌ను కూడా ఎంచుకోవచ్చు.</translation>
<translation id="5539070192556911367">Googleను చేరుకోవడం సాధ్యం కాలేదు</translation>
<translation id="557722062034137776">మీ డివైజ్‌ను రీసెట్ చేయడం వలన మీ Google ఖాతాలపై లేదా ఈ ఖాతాలకు సింక్ చేయ‌బ‌డిన‌ ఏదైనా డేటాపై ఎటువంటి ప్రభావం ఉండదు. అయితే, మీ డివైజ్‌లో లోకల్‌గా సేవ్ చేయబడిన అన్ని ఫైళ్లు తొలగించబడతాయి.</translation>
<translation id="5626172233890210551">బదులుగా పాస్‌వర్డ్‌ను ఉపయోగించండి</translation>
<translation id="5636996382092289526">మీరు <ph name="NETWORK_ID" />ను ఉపయోగించడానికి మొదట కొన్నిసెకన్లలో ఆటోమేటిక్‌గా తెరవబడే <ph name="LINK_START" />నెట్‌వర్క్ సైన్ ఇన్ పేజీని సందర్శించాలి<ph name="LINK_END" />. ఇది జరగకపోతే, నెట్‌వర్క్‌ను ఉపయోగించలేరు.</translation>
<translation id="5659964844710667266">ఈ <ph name="DEVICE_TYPE" /> కోసం పాస్‌వర్డ్‌ను క్రియేట్ చేయండి</translation>
<translation id="5684950556880280580">మీ పాస్‌వర్డ్ అప్‌డేట్ చేయబడింది</translation>
<translation id="5762787084360227629">Google ఖాతా సమాచారాన్ని ఎంటర్ చేయండి</translation>
<translation id="5764797882307050727">దయచేసి మీ పరికరంలో కొంత స్థలాన్ని ఖాళీ చేయండి.</translation>
<translation id="5765425701854290211">క్షమించండి, కొన్ని ఫైళ్లు పాడయ్యాయి. అప్‌డేట్ విజయవంతం కాలేదు. మీ సింక్ చేసిన‌ ఫైళ్లు సురక్షితంగా ఉన్నాయి.</translation>
<translation id="5770125698810550803">నావిగేషన్ బటన్‌లను చూపు</translation>
<translation id="5799478978078236781"><ph name="DEVICE_TYPE" /> చిట్కాలు, ఆఫర్‌లతో పాటు అప్‌డేట్‌లను పొందండి, ఫీడ్‌బ్యాక్‌ను షేర్ చేయండి.</translation>
<translation id="5804259315582798390">లోకల్ డేటా రికవరీని ఎనేబుల్ చేయడం విఫలమైంది</translation>
<translation id="5810809306422959727">తల్లిదండ్రుల నియంత్రణల కోసం ఈ ఖాతాకు అర్హత లేదు</translation>
<translation id="5852137567692933493">పునఃప్రారంభించి, పవర్‌వాష్ చేయి</translation>
<translation id="5856721540245522153">డీబగ్గింగ్ ఫీచ‌ర్‌లను ప్రారంభించండి</translation>
<translation id="5860491529813859533">ఆన్ చేయండి</translation>
<translation id="5895138241574237353">మళ్ళీ ప్రారంభించండి</translation>
<translation id="5895335062901455404">మీరు మీ Google ఖాతాతో సైన్ ఇన్ చేసినప్పుడు, ఏ ChromeOS Flex పరికరంలోనైనా మీరు సేవ్ చేసిన ప్రాధాన్యతలు, యాక్టివిటీ సిద్ధంగా ఉంటాయి. ఏది సింక్ చేయాలనే దాన్ని, మీరు సెట్టింగ్‌లలో ఎంచుకోవచ్చు.</translation>
<translation id="5939518447894949180">రీసెట్ చేయండి</translation>
<translation id="5959471481388474538">నెట్‌వర్క్ అందుబాటులో లేదు</translation>
<translation id="6016178549409952427"><ph name="TOTAL_ELEMENTS" />లో <ph name="CURRENT_ELEMENT" />వ అదనపు కంటెంట్‌కు నావిగేట్ చేయండి</translation>
<translation id="6040143037577758943">మూసివేయండి</translation>
<translation id="6055544610007596637">Google Play Store నుండి మీ <ph name="DEVICE_TYPE" /> కోసం యాప్‌లను ఇన్‌స్టాల్ చేయండి</translation>
<translation id="6071181508177083058">పాస్‌వర్డ్‌ను నిర్ధారించండి</translation>
<translation id="6125479973208104919">దురదృష్టవశాత్తూ, మీరు మీ ఖాతాను ఈ <ph name="DEVICE_TYPE" />కి మళ్లీ జోడించాలి.</translation>
<translation id="6165508094623778733">మరింత తెలుసుకోండి</translation>
<translation id="6170498031581934115">ADB డీబగ్గింగ్‌ను ఎనేబుల్ చేయడం సాధ్యపడలేదు. సెట్టింగ్‌లకు వెళ్లి, ఆపై మళ్లీ ట్రై చేయండి.</translation>
<translation id="6172020488605056255">చదవడంలో సహాయం చేయాడాన్ని ఉపయోగించడానికి రైట్‌-క్లిక్ చేయండి</translation>
<translation id="6173623053897475761">మీ పిన్‌ని మళ్లీ టైప్ చేయండి</translation>
<translation id="6202304368170870640">మీరు మీ పిన్‌ని ఉపయోగించి మీ పరికరంలో సైన్ ఇన్ చేయవచ్చు లేదా అన్‌లాక్ చేయవచ్చు.</translation>
<translation id="623261264391834964">'రాయడంలో సహాయపడు'ను ఉపయోగించడానికి, టెక్స్ట్ బాక్స్‌లో కుడి క్లిక్ చేయండి</translation>
<translation id="6280215091796946657">వేరొక ఖాతాతో సైన్ ఇన్ చేయండి</translation>
<translation id="6287713404380454515">సెక్యూరిటీ కారణాల దృష్ట్యా, మీ అడ్మినిస్ట్రేటర్ మీ డివైజ్ PINను, పాస్‌వర్డ్‌ను డిజేబుల్ చేశారు. ఇప్పటి నుండి, మీ <ph name="MANAGER" /> పాస్‌వర్డ్‌ను ఉపయోగించండి.</translation>
<translation id="6314819609899340042">మీరు ఈ <ph name="IDS_SHORT_PRODUCT_NAME" /> పరికరంలో డీబగ్గింగ్ ఫీచ‌ర్‌లను విజయవంతంగా ప్రారంభించారు.</translation>
<translation id="6380143666419481200">అంగీకరించి, కొనసాగండి</translation>
<translation id="6418511932144861495">కీలకమైన అప్‌డేట్‌ను ఇన్‌స్టాల్ చేయండి</translation>
<translation id="6480327114083866287"><ph name="MANAGER" /> ద్వారా మేనేజ్ చేయబడుతోంది</translation>
<translation id="6495266441917713704">Wi-Fiని బదిలీ చేయడం సాధ్యపడదు</translation>
<translation id="6515620015470298987">డివైజ్ కాన్ఫిగరేషన్ చెక్ సమస్య కారణంగా సైన్ ఇన్ విఫలమైంది. దయచేసి మీ <ph name="DEVICE_TYPE" />‌ను ఫ్యాక్టరీ రీసెట్ చేసి, మళ్లీ ట్రై చేయండి.</translation>
<translation id="6532527800157340614">మీ యాక్సెస్ టోకెన్‌ని పొందడం సాధ్యం కాలేదు కాబట్టి, సైన్ ఇన్ విఫలమైంది. దయచేసి మీ నెట్‌వర్క్ కనెక్షన్‌ను చెక్ చేసి, మళ్లీ ట్రై చేయండి.</translation>
<translation id="6607890859198268021"><ph name="USER_EMAIL" />ను ఇప్పటికే <ph name="DOMAIN" /> మేనేజ్ చేస్తోంది. వేరొక Google ఖాతాతో తల్లిదండ్రుల నియంత్రణలను ఉపయోగించడానికి, సెటప్‌ను పూర్తి చేశాక సైన్ అవుట్ చేసి, ఆపై సైన్ ఇన్ స్క్రీన్‌పై ఉన్న "వ్యక్తిని జోడించండి"ను ఎంచుకోండి.</translation>
<translation id="6648911618876616409">ఒక ముఖ్యమైన అప్‌డేట్ ఇన్‌స్టాల్ కావడానికి సిద్ధంగా ఉంది. ప్రారంభించడానికి సైన్ ఇన్ చేయండి.</translation>
<translation id="667752334740867460">Wi-Fi సమాచారాన్ని అందుకుంటోంది...</translation>
<translation id="6680442031740878064">అందుబాటులో ఉంది: <ph name="AVAILABLE_SPACE" /></translation>
<translation id="6722744767592605627">మీరు <ph name="EMAIL" />‌ను రికవర్ చేసుకోవచ్చు, కానీ లోకల్ డేటా తొలగించబడుతుంది.</translation>
<translation id="6789834167207639931">తర్వాతి స్క్రీన్‌లో మీ Google ఖాతా పాస్‌వర్డ్‌ను మళ్లీ ఎంటర్ చేసి, రికవరీని పూర్తి చేయండి</translation>
<translation id="6800893479155997609">మీ <ph name="DEVICE_TYPE" /> కోసం టాప్ యాప్‌లు</translation>
<translation id="6835762382653651563">దయచేసి మీ <ph name="DEVICE_TYPE" />ని అప్‌డేట్ చేయడానికి ఇంటర్నెట్‌కి కనెక్ట్ చేయండి.</translation>
<translation id="6839916869147598086">సైన్-ఇన్ మార్చబడింది</translation>
<translation id="6903907808598579934">సింక్‌ను ఆన్ చేయి</translation>
<translation id="6918733588290914545">Android ఫోన్‌తో క్విక్ సెటప్</translation>
<translation id="6955698182324067397">మీరు ChromeOS డీబగ్గింగ్ ఫీచర్‌లను ఎనేబుల్ చేస్తున్నారు, ఇది sshd daemonను సెటప్ చేస్తుంది అలాగే USB డిస్క్‌ల నుండి బూట్ చేయడాన్ని ఎనేబుల్ చేస్తుంది.</translation>
<translation id="6965382102122355670">సరే</translation>
<translation id="6981982820502123353">యాక్సెసిబిలిటీ</translation>
<translation id="6984652455487792101">మీరు ప్రాక్సీ సర్వర్‌ను ఉపయోగిస్తుంటే, ప్రాక్సీ సర్వర్ పని చేస్తోందని
    చెక్ చేయడానికి మీ ప్రాక్సీ సెట్టింగ్‌లను చెక్ చేయండి లేదా మీ నెట్‌వర్క్ అడ్మినిస్ట్రేటర్‌ను సంప్రదించండి. మీరు ప్రాక్సీ సర్వర్‌ను ఉపయోగించాల్సిన అవసరం లేదని మీరు అనుకుంటే, మీ <ph name="LINK_START" />ప్రాక్సీ సెట్టింగ్‌ల<ph name="LINK_END" />ను అడ్జస్ట్ చేయండి.</translation>
<translation id="6996245928508281884">మీ ఫోన్ బ్లూటూత్‌ను, Wi-Fiను ఆన్ చేయండి</translation>
<translation id="7077829361966535409">సైన్ ఇన్ పేజీ ప్రస్తుత ప్రాక్సీ సెట్టింగ్‌లను ఉపయోగించి లోడ్ కావడంలో విఫలమైంది. దయచేసి <ph name="GAIA_RELOAD_LINK_START" />మళ్లీ సైన్ ఇన్ చేయడానికి ప్రయత్నించండి<ph name="GAIA_RELOAD_LINK_END" /> లేదా విభిన్న <ph name="PROXY_SETTINGS_LINK_START" />ప్రాక్సీ సెట్టింగ్‌ల<ph name="PROXY_SETTINGS_LINK_END" />ను ఉపయోగించండి.</translation>
<translation id="7114054701490058191">పాస్‌‌వర్డ్‌లు సరిపోలలేదు</translation>
<translation id="7135729336746831607">బ్లూటూత్ ఆన్ చేయాలా?</translation>
<translation id="7141105143012495934">మీ ఖాతా వివరాలను తిరిగి పొందలేనందున సైన్-ఇన్ విఫలమైంది. దయచేసి మీ అడ్మినిస్ట్రేటర్‌ను సంప్రదించండి లేదా మళ్లీ ట్రై చేయండి.</translation>
<translation id="7144878232160441200">మళ్లీ ట్రై చేయండి</translation>
<translation id="7202337678781136582">మీ Android ఫోన్‌తో QR కోడ్‌ను స్కాన్ చేయండి</translation>
<translation id="7290242001003353852"><ph name="SAML_DOMAIN" /> హోస్ట్ చేసిన ఈ సైన్-ఇన్ సేవ, మీ కెమెరాను యాక్సెస్ చేస్తోంది.</translation>
<translation id="7329154610228416156">సెక్యూర్ కాని URL (<ph name="BLOCKED_URL" />)ను ఉపయోగించేలా కాన్ఫిగర్ చేయబడినందున సైన్-ఇన్ విఫలమైంది. దయచేసి మీ అడ్మినిస్ట్రేటర్‌ను సంప్రదించండి.</translation>
<translation id="7345706641791090287">మీ పాస్‌వర్డ్‌ను నిర్ధారించండి</translation>
<translation id="7352651011704765696">ఏదో తప్పు జరిగింది</translation>
<translation id="7476454130948140105">అప్‌డేట్ చేయడానికి తగినంత బ్యాటరీ ఛార్జింగ్ లేదు (<ph name="BATTERY_PERCENT" />%)</translation>
<translation id="7504187084873714912"><ph name="BEGIN_PARAGRAPH1" />ఎన్‌రోల్ చేసే ముందు, మీరు TPMను క్లియర్ చేయాల్సి ఉంటుంది, తద్వారా డివైజ్ యాజమాన్య హక్కును <ph name="DEVICE_OS" /> తీసుకోగలుగుతుంది.<ph name="END_PARAGRAPH1" />
        <ph name="BEGIN_PARAGRAPH2" />మీరు TPM డివైజ్‌ను మొత్తానికి కూడా ఆఫ్ చేయవచ్చు. మీ డేటా, సాఫ్ట్‌వేర్ ఎన్‌క్రిప్షన్ ద్వారా ఇప్పటికీ భద్రంగా స్టోర్ చేయబడుతుంది, కానీ హార్డ్‌వేర్ సపోర్ట్‌ను కలిగి ఉన్న సర్టిఫికెట్‌ల వంటి కొన్ని సెక్యూరిటీ ఫీచర్‌లు డిజేబుల్ అవుతాయి.<ph name="END_PARAGRAPH2" />
        <ph name="BEGIN_PARAGRAPH3" />సిస్టమ్ BIOS/UEFI సెట్టింగ్‌లను రీబూట్ చేయడం, ఇంకా ఎంటర్ చేయడం ద్వారా మీరు మీ TPM సెట్టింగ్‌లను మార్చవచ్చు. డివైజ్ మోడల్ ఆధారంగా దశలు మారుతూ ఉంటాయి. మరింత సమాచారం కోసం, మీరు రీబూట్ చేసే ముందు <ph name="DEVICE_OS" /> డాక్యుమెంటేషన్‌ను వేరొక డివైజ్‌లో తెరవండి: g.co/flex/TPMHelp.<ph name="END_PARAGRAPH3" /></translation>
<translation id="7543104066686362383">ఈ <ph name="IDS_SHORT_PRODUCT_NAME" /> పరికరంలో డీబగ్గింగ్ ఫీచ‌ర్‌లను ప్రారంభించండి</translation>
<translation id="7553242001898162573">మీ పాస్‌వర్డ్‌ను నమోదు చేయండి</translation>
<translation id="7556242789364317684">దురదృష్టవశాత్తూ, <ph name="SHORT_PRODUCT_NAME" /> మీ సెట్టింగ్‌లను రికవర్ చేయలేకపోయింది. ఎర్రర్‌ను ఫిక్స్ చేయడానికి, <ph name="SHORT_PRODUCT_NAME" /> మీ డివైజ్‌ను తప్పనిసరిగా పవర్‌వాష్‌తో రీసెట్ చేయాలి.</translation>
<translation id="7560756177962144929">మీ <ph name="DEVICE_TYPE" />‌ను సింక్ చేయండి</translation>
<translation id="7571643774869182231">అప్‌డేట్ కోసం తగినంత స్టోరేజ్‌ లేదు</translation>
<translation id="7622114377921274169">ఛార్జింగ్.</translation>
<translation id="7630426712700473382">ఈ పరికరం <ph name="MANAGER" /> ద్వారా మేనేజ్ చేయబడుతోంది, మీరు ప్రతిసారి సైన్ ఇన్ చేయాల్సి ఉంటుంది.</translation>
<translation id="7639914187072011620">సర్వర్ నుండి SAML మళ్లింపు URLను పొందడంలో విఫలమైంది</translation>
<translation id="7649070708921625228">సహాయం</translation>
<translation id="7658239707568436148">రద్దు చేయండి</translation>
<translation id="7659584679870740384">ఈ డివైజ్‌ను ఉపయోగించడానికి మీకు అధికారం లేదు. దయచేసి సైన్-ఇన్ అనుమతి కోసం అడ్మినిస్ట్రేటర్‌ను సంప్రదించండి.</translation>
<translation id="7660116474961254898">మీ ఫోన్‌లోని సూచనలను ఫాలో అవ్వండి</translation>
<translation id="7671139479636735732">మీ ఐడియాలను సులభంగా విజువలైజ్ చేయడానికి రైట్-క్లిక్ చేయండి</translation>
<translation id="770831926727930011">మీ లోకల్ డేటాను మీ పాత పాస్‌వర్డ్ భద్రపరుస్తోంది. మీ పాత పాస్‌వర్డ్‌ను ఎంటర్ చేసి, లోకల్ డేటాను రికవర్ చేయండి.</translation>
<translation id="7722040605881499779">అప్‌డేట్ చేయడానికి కావాల్సిన స్థలం: <ph name="NECESSARY_SPACE" /></translation>
<translation id="7792012425874949788">సైన్ ఇన్ చేయడంలో ఏదో తప్పు జరిగింది</translation>
<translation id="780301667611848630">వద్దు</translation>
<translation id="7803657407897251194">మీ Android పరికరంతో సెటప్‌ను కొనసాగించడానికి, మీ <ph name="DEVICE_TYPE" />‌ను నెట్‌వర్క్‌కు కనెక్ట్ చేయండి</translation>
<translation id="7851457902707056880">సైన్-ఇన్ అనేది, యజమాని ఖాతాకు మాత్రమే పరిమితం చేయబడింది. దయచేసి రీబూట్ చేసి యజమాని ఖాతాతో సైన్ ఇన్ చేయండి. మెషీన్ 30 సెకన్లలో ఆటోమేటిక్‌గా రీబూట్ అవుతుంది.</translation>
<translation id="7870730066603611552">సెటప్ చేసిన తర్వాత సింక్ ఎంపికలను రివ్యూ చేయండి</translation>
<translation id="7883792253546618164">ఏ సమయంలో అయినా సబ్‌స్క్రిప్షన్‌ను తీసివేయండి.</translation>
<translation id="7906440585529721295">లోకల్ డేటా తొలగించబడుతుంది</translation>
<translation id="7943311690198910993">సైన్ ఇన్ పద్ధతి అప్‌డేట్ చేయబడింది</translation>
<translation id="7968982339740310781">వివరాలను చూడండి</translation>
<translation id="7982083145464587921">ఈ ఎర్రర్‌ను ఫిక్స్ చేయడానికి దయచేసి మీ డివైజ్‌ను రీస్టార్ట్ చేయండి.</translation>
<translation id="7990958035181555539">మీ Android ఫోన్ నుండి WiFiని ఆటోమేటిక్‌గా బదిలీ చేయండి</translation>
<translation id="8054563304616131773">దయచేసి చెల్లుబాటు అయ్యే ఈమెయిల్‌ అడ్రస్‌ను నమోదు చేయండి</translation>
<translation id="8065144531309810062">మరింత క్రియేటివ్‌గా, మరింత ప్రొడక్టివ్‌గా ఉండటానికి Googleకు చెందిన AI టెక్నాలజీలను ఉపయోగించండి</translation>
<translation id="8098616321286360457">నెట్‌వర్క్ కనెక్షన్ అవసరం</translation>
<translation id="8131740175452115882">నిర్ధారించు</translation>
<translation id="8146177459103116374">మీరు ఇప్పటికే ఈ పరికరంలో నమోదు చేసి ఉంటే, మీరు <ph name="LINK2_START" />ఇప్పటికే ఉన్న వినియోగదారు వలే సైన్ ఇన్ చేయవచ్చు<ph name="LINK2_END" />.</translation>
<translation id="8146793085009540321">సైన్-ఇన్ విఫలమైంది. దయచేసి మీ నిర్వాహకులను సంప్రదించండి లేదా మళ్లీ ట్రై చేయండి.</translation>
<translation id="8202160505685531999">దయచేసి మీ <ph name="DEVICE_TYPE" /> ప్రొఫైల్‌ను అప్‌డేట్ చేయ‌డానికి మీ పాస్‌వర్డ్‌ను మళ్లీ నమోదు చేయండి.</translation>
<translation id="8241806945692107836">పరికర కాన్ఫిగరేషన్‌ను గుర్తిస్తోంది...</translation>
<translation id="8242426110754782860">కొనసాగు</translation>
<translation id="826905130698769948">చెల్లని క్లయింట్ సర్టిఫికెట్</translation>
<translation id="8274924778568117936">అప్‌డేట్ పూర్తయ్యే వరకు మీ <ph name="DEVICE_TYPE" />ని ఆఫ్ చేయవద్దు లేదా మూసివేయవద్దు. ఇన‌స్ట‌లేష‌న్‌ పూర్తయిన తర్వాత మీ <ph name="DEVICE_TYPE" /> పునఃప్రారంభమవుతుంది.</translation>
<translation id="8281886186245836920">స్కిప్ చేయండి</translation>
<translation id="8304383784961451596">ఈ డివైజ్‌ను ఉపయోగించడానికి మీకు అనుమతిలేదు. సైన్ ఇన్ అనుమతి కోసం దయచేసి అడ్మినిస్ట్రేటర్‌ను కాంటాక్ట్ చేయండి లేదా Family Link ద్వారా పర్యవేక్షించబడే Google ఖాతాతో సైన్ ఇన్ చేయండి.</translation>
<translation id="8354034204605718473">మీ చిన్నారి PIN జోడించబడింది</translation>
<translation id="8366396658833131068">మీ నెట్‌వర్క్ కనెక్టివిటీ పునరుద్ధరించబడింది. దయచేసి వేరే నెట్‌వర్క్‌ను ఎంచుకోండి లేదా మీ కియోస్క్ యాప్‌ను ప్రారంభించడానికి కింది 'కొనసాగించండి' బటన్ నొక్కండి.</translation>
<translation id="8425768983279799676">మీరు మీ PINను ఉపయోగించి మీ డివైజ్‌ను అన్‌లాక్ చేయవచ్చు.</translation>
<translation id="843173223122814223">AIతో బ్యాక్‌గ్రౌండ్‌లను క్రియేట్ చేయండి</translation>
<translation id="8452105022015742247">మీ Android ఫోన్ నుండి Google ఖాతా సమాచారం బదిలీ చేయబడుతోంది</translation>
<translation id="8524841856047224176">వీడియో కాల్స్‌తో పాటు మరిన్నింటి కోసం మీ కెమెరా బ్యాక్‌గ్రౌండ్‌లను వ్యక్తిగతీకరించుకోండి</translation>
<translation id="8569673829373920831"><ph name="APP_NAME" /> గురించి మరింత సమాచారం</translation>
<translation id="8628232294964836490">మీ ఫోన్‌లోని సూచనలను ఫాలో అయ్యి, QR కోడ్‌ను స్కాన్ చేయండి. మీ ఫోన్ బ్లూటూత్ ఆన్‌లో ఉందని నిర్ధారించుకోండి.
        <ph name="BR" />
    <ph name="BR" />
    సమీపంలోని డివైజ్‌లకు <ph name="QUICK_START_DEVICE_DISPLAY_NAME" />‌గా కనిపిస్తుంది...</translation>
<translation id="8655972064210167941">మీ పాస్‌వర్డ్‌ను వెరిఫై చేయలేకపోవడం వల్ల సైన్-ఇన్ విఫలమైంది. దయచేసి మీ అడ్మినిస్ట్రేటర్‌ను సంప్రదించండి లేదా మళ్లీ ట్రై చేయండి.</translation>
<translation id="8674903726754070732">దురదృష్టవశాత్తూ, తప్పుగా ఫార్మాట్ చేయబడిన హార్డ్‌వేర్ IDతో మీ కంప్యూటర్ కాన్ఫిగర్ చేయబడింది. ఇది సెక్యూరిటీ పరిష్కారాలతో అప్‌డేట్ కాకుండా ChromeOSను నిరోధిస్తుంది, అలాగే మీ కంప్యూటర్ <ph name="BEGIN_BOLD" />హానికరమైన సాఫ్ట్‌వేర్ దాడులకు గురి కావచ్చు<ph name="END_BOLD" />.</translation>
<translation id="8695139659682234808">సెటప్ పూర్తి అయ్యాక తల్లిదండ్రుల నియంత్రణలను జోడించండి</translation>
<translation id="8725066075913043281">మళ్ళీ ప్రయత్నించండి</translation>
<translation id="8730621377337864115">పూర్తయింది</translation>
<translation id="8740086188450289493">Google ఖాతా పాస్‌వర్డ్‌ను ఉపయోగించండి</translation>
<translation id="8740247629089392745">మీరు ఈ Chromebookను <ph name="SUPERVISED_USER_NAME" />కు ఇవ్వవచ్చు. సెటప్ దాదాపు పూర్తయింది, మరిన్ని విషయాలను తెలుసుకునే సమయం ఆసన్నమైంది.</translation>
<translation id="8759753423332885148">మరింత తెలుసుకోండి.</translation>
<translation id="8777628254805677039">మూల పాస్‌వర్డ్</translation>
<translation id="8794548468611058947">సైన్ ఇన్ చేయడానికి మీ Google ఖాతా పాస్‌వర్డ్‌ను ఎంటర్ చేయడానికి బదులుగా, మీరు ఈ <ph name="DEVICE_TYPE" /> కోసం PINను క్రియేట్ చేయవచ్చు</translation>
<translation id="8830796635868321089">ప్రస్తుత ప్రాక్సీ సెట్టింగ్‌లను ఉపయోగించి అప్‌‌డేట్‌ను చెక్ చేయడం విఫలమైంది. దయచేసి మీ <ph name="PROXY_SETTINGS_LINK_START" />ప్రాక్సీ సెట్టింగ్‌ల<ph name="PROXY_SETTINGS_LINK_END" />ను సర్దుబాటు చేయండి.</translation>
<translation id="885746075120788020">మీరు మీ Google ఖాతాతో సైన్ ఇన్ చేసినప్పుడు, ఏ ChromeOS పరికరంలోనైనా మీరు సేవ్ చేసిన ప్రాధాన్యతలు, యాక్టివిటీ సిద్ధంగా ఉంటాయి. ఏది సింక్ చేయాలనే దాన్ని, మీరు సెట్టింగ్‌లలో ఎంచుకోవచ్చు.</translation>
<translation id="8875221558267407626">కంటెంట్‌ను సారాంశీకరించండి, క్లిష్టమైన భాషను సులభతరం చేయండి, లేదా ప్రశ్నలను అడగండి</translation>
<translation id="8913163265790894442">మీ ఫోన్‌తో <ph name="DEVICE_TYPE" />‌ను సులభంగా సెటప్ చేయండి. మీ పాస్‌వర్డ్‌లను మాన్యువల్‌గా ఎంటర్ చేయకుండానే మీ Wi-Fiను, Google ఖాతాను మీరు జోడించవచ్చు.
        <ph name="BR" />
        <ph name="BR" />
        <ph name="DEVICE_TYPE" />‌లా కనబడుతుంది...</translation>
<translation id="8946359700442089734">డీబగ్గింగ్ ఫీచ‌ర్‌లు ఈ <ph name="IDS_SHORT_PRODUCT_NAME" /> పరికరంలో పూర్తిగా ప్రారంభించబడలేదు.</translation>
<translation id="8965037249707889821">పాత పాస్‌వర్డ్‌ను నమోదు చేయండి</translation>
<translation id="8975396729541388937">మీరు అందుకునే ఇమెయిల్‌లలోని లింక్‌ను క్లిక్ చేయడం ద్వారా ఎప్పుడైనా సబ్‌స్క్రిప్షన్‌ను తీసివేయవచ్చు.</translation>
<translation id="9033765790910064284">ఏమైనప్పటికీ కొనసాగించండి</translation>
<translation id="903480517321259405">PINను మళ్లీ టైప్ చేయండి</translation>
<translation id="9076523132036239772">క్షమించండి, మీ ఈమెయిల్‌ లేదా పాస్‌వర్డ్ ధృవీకరించబడలేదు. మొదట నెట్‌వర్క్‌కి కనెక్ట్ చేయడానికి ప్రయత్నించండి.</translation>
<translation id="9217002308921247002"><ph name="BEGIN_PARAGRAPH1" /><ph name="DEVICE_TYPE" />‌కు మాత్రమే ప్రత్యేకమైనది.<ph name="END_PARAGRAPH1" />
        <ph name="BEGIN_PARAGRAPH2" />జెనరేటివ్ AI ప్రయోగాత్మకమైనది, ఇంకా ప్రారంభ స్థాయి అభివృద్ధి దశలోనే ఉంది, ప్రస్తుతానికి అది పరిమిత స్థాయిలో అందుబాటులో ఉంది.<ph name="END_PARAGRAPH2" /></translation>
<translation id="936479314588646618">మీ ఫోన్‌తో <ph name="DEVICE_TYPE" />‌ను సులభంగా సెటప్ చేయండి. మీరు మీ పాస్‌వర్డ్‌ను మాన్యువల్‌గా ఎంటర్ చేయకుండానే మీ Google ఖాతాను జోడించవచ్చు.
        <ph name="BR" />
        <ph name="BR" />
        <ph name="DEVICE_TYPE" />‌లా కనబడుతుంది...</translation>
</translationbundle>