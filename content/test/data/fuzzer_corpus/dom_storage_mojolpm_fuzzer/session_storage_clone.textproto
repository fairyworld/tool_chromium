# Session storage: Bind the namespace, Clone it, then exercise storage areas
# in the original namespace. Covers SessionStorageNamespace::Clone.

# actions[0]: Bind the SessionStorageNamespace remote.
actions {
  new_session_storage_namespace {
    id: 0
  }
}
# actions[1]: Clone to a fresh 36-char namespace id.
actions {
  session_storage_namespace_remote_action {
    id: 0
    m_clone {
      m_clone_to_namespace: "11111111_2222_3333_4444_555555555555"
    }
  }
}

# actions[2]: IO-thread drain.
actions { run_thread { id: IO } }

# actions[3]: Clone again to a different id (repeated clones).
actions {
  session_storage_namespace_remote_action {
    id: 0
    m_clone {
      m_clone_to_namespace: "aaaaaaaa_bbbb_cccc_dddd_eeeeeeeeeeee"
    }
  }
}

# actions[4]: Bind a session area on ORIGIN_A in the source namespace.
actions {
  new_session_storage_area {
    id: 0
    origin_id: ORIGIN_A
    renderer_id: RENDERER_A
  }
}

# actions[5]: Put a value so the area has data for the clone to copy.
actions {
  storage_area_remote_action {
    id: 0
    m_put {
      m_key { values { value: 99 } values { value: 107 } }
      m_value { values { value: 99 } values { value: 118 } }
    }
  }
}

# Sequence 0: Bind namespace, clone, drain.
sequences { action_indexes: [0, 1, 2] }
# Sequence 1: Put data then clone (clone after writes), drain.
sequences { action_indexes: [4, 5, 1, 2] }
# Sequence 2: Multiple clones in a row, drain.
sequences { action_indexes: [0, 1, 3, 2] }

sequence_indexes: [0, 1, 2]
