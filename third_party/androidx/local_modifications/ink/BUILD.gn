import("//build/config/android/rules.gni")
import("//third_party/jni_zero/jni_zero.gni")

generate_jni("ink_jni_headers") {
  sources = [ "java/org/chromium/androidx/InkJniLoader.java" ]
}

android_library("ink_java") {
  visibility = [ "//third_party/androidx:*" ]
  sources = [ "java/org/chromium/androidx/InkJniLoader.java" ]
  deps = [
    ":ink_jni_headers_java",
    "//third_party/jni_zero:jni_zero_java",
  ]
}

source_set("ink_native") {
  sources = [ "ink_jni_loader.cc" ]
  configs -= [ "//build/config/compiler:chromium_code" ]
  configs += [ "//build/config/compiler:no_chromium_code" ]

  deps = [
    ":ink_jni_headers",
    "//third_party/ink:ink_jni_registration",
    "//third_party/jni_zero",
  ]
}
