# Generate protobuf Well-Known Types (WKT) as proto_library targets.
#
# Example usage:
#   proto_wkt("example_proto") {
#     sources = [ "src/google/protobuf/example.proto" ]
#   }
#
# Parameters:
#
#   sources (required)
#       List of proto files to compile.
#
#   full_target_name (optional)
#       Generate full protobuf WKT target in addition to the lite target with
#       this name.
#
#       Full versions of protobuf WKTs should not be used, as they can conflict
#       with lite versions.
#
#   full_target_visibility (optional, default empty)
#       Visibility for the full protobuf WKT target.

import("proto_library.gni")

template("proto_wkt") {
  assert(string_replace(target_name + ".END", "_proto.END", "") !=
             target_name + ".END",
         "proto_wkt target name must end with _proto: $target_name")

  if (defined(invoker.full_target_name)) {
    _prefix = string_replace(target_name + ".END", "_proto.END", "")
    _expected_full_target_name = "${_prefix}_full_proto"
    assert(
        invoker.full_target_name == _expected_full_target_name,
        "full_target_name must be ${_expected_full_target_name} for target ${target_name}")
  }

  _current_dir = rebase_path(".", "//")
  _proto_out_dir_lite = "$_current_dir/lite/$target_name/src"
  _proto_out_dir_full = "$_current_dir/full/$target_name/src"

  # The Lite version of this WKT.
  proto_library(target_name) {
    sources = invoker.sources
    proto_in_dir = "src"
    proto_out_dir = "$_proto_out_dir_lite"
    cc_generator_options = "lite"
  }

  if (defined(invoker.full_target_name)) {
    _full_visibility = []
    if (defined(invoker.full_target_visibility)) {
      _full_visibility += invoker.full_target_visibility
    }

    # Full protos are registered globally and registering them twice causes a
    # crash. To avoid this we make them components, which are shared libraries
    # in component builds.
    _proto_target_name = "${invoker.full_target_name}__proto"
    proto_library(_proto_target_name) {
      sources = invoker.sources
      visibility = [ ":${invoker.full_target_name}" ]
      proto_in_dir = "src"
      proto_out_dir = "$_proto_out_dir_full"
      use_protobuf_full = true
      component_build_force_source_set = true

      if (!is_win) {
        # Ensure symbols are exported across shared library boundaries.
        extra_configs = [ "//build/config/gcc:symbol_visibility_default" ]
      }
    }

    # Other proto_library targets depending on this target expect it to be a
    # proto_library, which automatically generates these helper targets. Since
    # the public target is defined as a component instead, we must manually
    # define these targets and forward dependencies to the internal
    # proto_library's helper targets.
    group("${invoker.full_target_name}_input_group") {
      public_deps = [ ":${_proto_target_name}_input_group" ]
    }
    group("${invoker.full_target_name}_gen") {
      public_deps = [ ":${_proto_target_name}_gen" ]
    }

    component(invoker.full_target_name) {
      if (defined(invoker.full_target_visibility)) {
        visibility = _full_visibility
      }
      sources = [ "placeholder.cc" ]
      public_deps = [
        ":$_proto_target_name",
        "//third_party/protobuf:protobuf_full",
      ]
    }
  } else {
    not_needed([ "_proto_out_dir_full" ])
  }
}
