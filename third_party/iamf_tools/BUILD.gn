test("iamf_tools_lib_fuzz_tests") {
  sources = [
    "fuzz/get_test_path.cc",
    "src/iamf/api/decoder/tests/iamf_decoder_fuzz_test.cc",
  ]
  include_dirs = [
    ".",
    "src",
    "src/iamf/cli/tests/portable",
    "//third_party/abseil-cpp",
    "//third_party/opus/src",
  ]
  deps = [
    ":iamf_tools_lib",
    "//base/test:test_support",
    "//third_party/abseil-cpp:absl",
    "//third_party/fuzztest",
    "//third_party/fuzztest:fuzztest_gtest_main",
  ]
}
config("strip_errors_config") {
  cflags_cc = [
    "-include",
    rebase_path("strip_errors.h", root_build_dir),
  ]
}

static_library("iamf_tools_lib") {
  sources = iamf_tools_sources + iamf_tools_headers
  include_dirs = [
    "src",
    "//third_party/abseil-cpp",
    "//third_party/opus/src",
  ]
  deps = [
    "//third_party/abseil-cpp:absl",
    "//third_party/opus",
  ]
  defines = [
    "IAMF_TOOLS_DISABLE_AAC_DECODER",
    "IAMF_TOOLS_DISABLE_FLAC_DECODER",
    "IAMF_TOOLS_DISABLE_BINAURAL_RENDERING",
  ]
  if (!is_debug) {
    configs += [ ":strip_errors_config" ]
  }
  visibility = [
    ":*",
    "//media/filters:*",
  ]
}
