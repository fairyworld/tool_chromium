import("//testing/test.gni")
import("//third_party/protobuf/proto_library.gni")

config("federated_compute_include") {
  include_dirs = [
    "chromium",
    "src",
  ]
}

source_set("base") {
  public = [
    "src/fcp/base/base_name.h",
    "src/fcp/base/clock.h",
    "src/fcp/base/compression.h",
    "src/fcp/base/digest.h",
    "src/fcp/base/monitoring.h",
    "src/fcp/base/platform.h",
    "src/fcp/base/random_token.h",
    "src/fcp/base/scheduler.h",
    "src/fcp/base/time_util.h",
    "src/fcp/base/wall_clock_stopwatch.h",
  ]

  sources = [
    "src/fcp/base/base_name.cc",
    "src/fcp/base/clock.cc",
    "src/fcp/base/compression.cc",
    "src/fcp/base/digest.cc",
    "src/fcp/base/monitoring.cc",
    "src/fcp/base/platform.cc",
    "src/fcp/base/random_token.cc",
    "src/fcp/base/scheduler.cc",
    "src/fcp/base/time_util.cc",
    "src/fcp/base/wall_clock_stopwatch.cc",
  ]

  configs -= [ "//build/config/compiler:chromium_code" ]
  configs += [ "//build/config/compiler:no_chromium_code" ]

  public_configs = [ ":federated_compute_include" ]

  deps = [
    "//third_party/abseil-cpp:absl",
    "//third_party/boringssl",
    "//third_party/protobuf:duration_proto",
    "//third_party/protobuf:io_gzip_stream",
    "//third_party/protobuf:timestamp_proto",
  ]
}

proto_library("confidential_compute_proto") {
  sources = [
    "src/fcp/protos/confidentialcompute/aggregation_client_payload.proto",
    "src/fcp/protos/confidentialcompute/data_upload_config.proto",
    "src/fcp/protos/confidentialcompute/key.proto",
    "src/fcp/protos/confidentialcompute/payload_transparency.proto",
    "src/fcp/protos/confidentialcompute/signed_endorsements.proto",
    "src/fcp/protos/federatedcompute/confidential_encryption_config.proto",
  ]

  deps = [
    "//third_party/oak:oak_proto",
    "//third_party/oak:proto_attestation_reference_value_proto",
    "//third_party/protobuf:timestamp_proto",
  ]

  import_dirs = [
    "//third_party/oak/chromium",
    "//third_party/protobuf/src",
  ]

  proto_in_dir = "src"

  cc_generator_options = "lite"
}

source_set("confidential_compute") {
  public = [
    "src/fcp/confidentialcompute/cose.h",
    "src/fcp/confidentialcompute/crypto.h",
  ]

  sources = [
    "chromium/fcp/confidentialcompute/cose.cc",
    "src/fcp/confidentialcompute/crypto.cc",
  ]

  configs -= [ "//build/config/compiler:chromium_code" ]
  configs += [ "//build/config/compiler:no_chromium_code" ]

  public_configs = [ ":federated_compute_include" ]

  public_deps = [
    ":confidential_compute_proto",
    "//third_party/oak:oak_proto",
  ]

  deps = [
    ":base",
    "//base",
    "//components/cbor",
  ]
}

proto_library("federatedcompute_proto") {
  sources = [
    "chromium/fcp/protos/federated_api.proto",
    "chromium/fcp/protos/federatedcompute/aggregations.proto",
    "chromium/fcp/protos/federatedcompute/common.proto",
    "chromium/fcp/protos/federatedcompute/confidential_aggregations.proto",
    "chromium/fcp/protos/federatedcompute/eligibility_eval_tasks.proto",
    "chromium/fcp/protos/federatedcompute/secure_aggregations.proto",
    "chromium/fcp/protos/federatedcompute/task_assignments.proto",
    "chromium/fcp/secagg/shared/secagg_messages.proto",
  ]

  deps = [
    "//third_party/federated_compute/third_party/googleapis:google_rpc_code_proto",
    "//third_party/federated_compute/third_party/googleapis:google_rpc_status_proto",
    "//third_party/protobuf:any_proto",
    "//third_party/protobuf:duration_proto",
  ]

  import_dirs = [
    "//third_party/oak/chromium",
    "//third_party/federated_compute/third_party/googleapis/src",
  ]

  proto_in_dir = "chromium"
  cc_generator_options = "lite"
}

source_set("confidential_compute_crypto_test_util") {
  public = [ "src/fcp/confidentialcompute/crypto_test_util.h" ]
  sources = [ "src/fcp/confidentialcompute/crypto_test_util.cc" ]

  configs -= [ "//build/config/compiler:chromium_code" ]
  configs += [ "//build/config/compiler:no_chromium_code" ]

  public_configs = [ ":federated_compute_include" ]

  deps = [
    ":base",
    ":confidential_compute",
    "//third_party/abseil-cpp:absl",
    "//third_party/boringssl",
  ]
}

if (!is_win && !is_android && !is_ios && !is_fuchsia) {
  test("federated_compute_tests") {
    testonly = true
    public = [ "chromium/fcp/testing/testing.h" ]

    sources = [
      "chromium/fcp/confidentialcompute/cose_test.cc",
      "chromium/fcp/testing/testing.cc",
    ]

    deps = [
      ":base",
      ":confidential_compute",
      "//base",
      "//components/cbor",
      "//testing/gmock",
      "//testing/gtest",
      "//testing/gtest:gtest_main",
      "//third_party/abseil-cpp:absl",
      "//third_party/protobuf:protobuf_full",
      "//third_party/protobuf:struct_proto",
    ]
  }
}
