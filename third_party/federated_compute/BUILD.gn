import("//testing/test.gni")
import("//third_party/protobuf/proto_library.gni")

config("federated_compute_include") {
  include_dirs = [
    "chromium",
    "src",
  ]
}

config("compat_no_flock") {
  if (is_win) {
    include_dirs = [ "compat-no-flock" ]
  }
}

source_set("base") {
  public = [
    "src/fcp/base/base_name.h",
    "src/fcp/base/compression.h",
    "src/fcp/base/digest.h",
    "src/fcp/base/monitoring.h",
    "src/fcp/base/platform.h",
    "src/fcp/base/random_token.h",
    "src/fcp/base/scheduler.h",
    "src/fcp/base/time_util.h",
    "src/fcp/base/wall_clock_stopwatch.h",
  ]

  sources = [
    "src/fcp/base/base_name.cc",
    "src/fcp/base/compression.cc",
    "src/fcp/base/digest.cc",
    "src/fcp/base/platform.cc",
    "src/fcp/base/random_token.cc",
    "src/fcp/base/scheduler.cc",
    "src/fcp/base/time_util.cc",
    "src/fcp/base/wall_clock_stopwatch.cc",
  ]

  configs -= [ "//build/config/compiler:chromium_code" ]
