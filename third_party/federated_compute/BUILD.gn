  configs -= [ "//build/config/compiler:chromium_code" ]
  configs += [ "//build/config/compiler:no_chromium_code" ]

  public_configs = [ ":federated_compute_include" ]

  configs += [
    # Temporary workaround for Windows, where flock() is not natively supported.
    #
    # Stubbing flock to return 0 (success) is safe (in this specific case)
    # because the FCP service in Chrome is a singleton (per profile), and Chrome
    # enforces a single app instance per data directory, so concurrent FCP
    # processes writing to the same directory do not exist.
    ":compat_no_flock",
  ]

  public_deps = [
    ":base",
    ":client_proto",
    ":confidential_compute_proto",
    ":federatedcompute_proto",
    "third_party/tensorflow-federated:tensorflow_federated",
    "//third_party/abseil-cpp:absl",
