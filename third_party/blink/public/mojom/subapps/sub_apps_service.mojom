module blink.mojom;

enum SubAppsServiceResultCode {
  kWrongContext,
  kUserDeclined,
  kLimitExceeded,
  kWebAppsNotUserInstallable,
  kGenericError,
};

enum SubAppsServiceAddResultType {
  kSuccess,
  kScopeOverlap,
  kRecursiveInstall,
  kInvalidManifest,
  kAlreadyInstalled,
  kGenericError,
};

// `manifest_id` is the sub app id generated according to
// https://www.w3.org/TR/appmanifest/#dfn-identity, but only the path component
// of the full url.
// `install_path` is a path to a page hosting or containing a link to the
// app's manifest.
struct SubAppsServiceAddResult {
  string install_path;
  string? manifest_id;
  SubAppsServiceAddResultType result_type;
};

struct SubAppsServiceListResultEntry {
  string manifest_id;
  string app_name;
};

enum SubAppsServiceRemoveResultType {
  kSuccess,
  kNotFound,
  kGenericError,
};

struct SubAppsServiceRemoveResult {
  string manifest_id;
  SubAppsServiceRemoveResultType result_type;
};

// Sub Apps APIs allow installed IWAs to install shortcuts to their various
// sub-parts by means of installing the sub-component.
// Example: main app which provides a full set of office productivity tools
// creates a new shortcut to itself with `spreadsheet` as the install_path
// effectively adding the Spreadsheet app to the launcher surface.
// NOTE: This Mojo interface is per-frame, there is one logical instance per
// frame, and it's main-frame only. It is only valid for already-installed apps.
interface SubAppsService {
  // Installs one or more sub-apps of an already-installed app corresponding to
  // this instance of SubAppsService.
  Add(array<string> install_paths)
      => result<array<SubAppsServiceAddResult>, SubAppsServiceResultCode>;

  // List all sub-apps installed by the app making the API call.
  List()
      => result<array<SubAppsServiceListResultEntry>, SubAppsServiceResultCode>;

  // Uninstalls the sub-apps represented by the given argument previously
  // installed via the `Add` method by the same app making the current API call.
  Remove(array<string> manifest_ids)
      => result<array<SubAppsServiceRemoveResult>, SubAppsServiceResultCode>;
};
