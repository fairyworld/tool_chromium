// https://github.com/MicrosoftEdge/MSEdgeExplainers/blob/main/WebInstall/explainer.md

dictionary InstallParams {
  required USVString manifest;
  // If present, must be a valid absolute URL. Pass undefined, null, or omit
  // completely if the JSON at `manifest` contains an `id` field.
  USVString? id;
};
