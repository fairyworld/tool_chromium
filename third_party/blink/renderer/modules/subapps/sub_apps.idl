[
  ImplementedAs=SubApps,
  SecureContext,
  Exposed=Window,
  RuntimeEnabled=SubApps,
  IsolatedContext
] partial interface Window {
  [SameObject] readonly attribute SubApps subApps;
};

dictionary SubAppsAddResponse {
  record<USVString, USVString> installedApps;
  record<USVString, DOMException> failedApps;
};

dictionary SubAppsRemoveResponse {
  sequence<USVString> removedApps;
  record<USVString, DOMException> failedApps;
};

dictionary SubAppsListResult {
  required DOMString appName;
};

[
  Exposed=Window,
  SecureContext,
  RuntimeEnabled=SubApps,
  IsolatedContext
] interface SubApps {
  [CallWith=ScriptState, RaisesException, MeasureAs=SubAppsAdd] Promise<SubAppsAddResponse> add(sequence<USVString> install_paths);
  [CallWith=ScriptState, RaisesException, MeasureAs=SubAppsRemove] Promise<SubAppsRemoveResponse> remove(sequence<USVString> manifest_ids);
  [CallWith=ScriptState, RaisesException, MeasureAs=SubAppsList] Promise<record<USVString, SubAppsListResult>> list();
};
