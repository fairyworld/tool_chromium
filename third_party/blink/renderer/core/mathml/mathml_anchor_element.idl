// https://w3c.github.io/mathml-core/#the-a-element
[RuntimeEnabled=MathMLAnchorElement]
interface MathMLAnchorElement : MathMLElement {
    [CEReactions, Reflect] attribute USVString href;
    [CEReactions, Reflect] attribute DOMString target;

};

MathMLAnchorElement includes HyperlinkElementUtils;