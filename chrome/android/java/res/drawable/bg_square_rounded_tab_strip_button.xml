<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
  <!-- Set button background to 32dp x 32dp matching standard tab strip buttons -->
  <size
      android:width="32dp"
      android:height="32dp" />
  <!-- Apply 8dp rounded corner radius for a rounded square look -->
  <corners android:radius="8dp" />
  <solid android:color="@android:color/white" />
</shape>
