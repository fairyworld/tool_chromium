source_set("memory_bank") {
  sources = [
    "memory_bank.h",
    "memory_bank_entry.h",
  ]

  public_deps = [
    "//base",
    "//url",
  ]
}

source_set("impl") {
  sources = [
    "in_memory_memory_bank.cc",
    "in_memory_memory_bank.h",
    "noop_memory_bank.cc",
    "noop_memory_bank.h",
  ]

  public_deps = [
    ":memory_bank",
    "//base",
    "//url",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "in_memory_memory_bank_unittest.cc" ]

  deps = [
    ":impl",
    ":memory_bank",
    "//base",
    "//base/test:test_support",
    "//testing/gtest",
    "//url",
  ]
}
