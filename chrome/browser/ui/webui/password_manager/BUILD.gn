import("//build/config/features.gni")
import("//mojo/public/tools/bindings/mojom.gni")

mojom("mojo_bindings") {
  sources = [ "password_manager.mojom" ]
  webui_module_path = "/"
  public_deps = [
    "//mojo/public/mojom/base",
    "//url/mojom:url_mojom_gurl",
  ]
}

source_set("password_manager_ui_handler") {
  sources = [ "password_manager_ui_handler.cc" ]
  public = [ "password_manager_ui_handler.h" ]
  deps = [
    ":mojo_bindings",
    "//chrome/browser/extensions",
    "//chrome/browser/sync",
    "//components/password_manager/core/browser",
    "//content/public/browser",
    "//mojo/public/cpp/bindings",
  ]
}

source_set("promo_card") {
  sources = [ "promo_card.cc" ]
  public = [ "promo_card.h" ]
  public_deps = [ "//chrome/browser:browser_public_dependencies" ]
  deps = [
    "//base",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/sync",
    "//chrome/browser/user_education",
    "//chrome/browser/web_applications",
    "//chrome/common",
    "//components/password_manager/core/browser",
    "//components/password_manager/core/common",
    "//components/prefs",
    "//components/sync/service",
    "//ui/base",
  ]
}

source_set("promo_cards_handler") {
  sources = [ "promo_cards_handler.cc" ]
  public = [ "promo_cards_handler.h" ]
  public_deps = [ "//chrome/browser:browser_public_dependencies" ]
  deps = [
    ":promo_card",
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser/extensions",
    "//chrome/browser/lifetime",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/sync",
    "//chrome/browser/ui/webui/password_manager/promo_cards",
    "//components/os_crypt/async/browser",
    "//components/os_crypt/async/common",
    "//components/password_manager/core/common",
    "//components/prefs",
    "//content/public/browser",
    "//ui/base",
  ]
}

source_set("password_manager_ui") {
  sources = [
    "password_manager_ui.cc",
    "sync_handler.cc",
  ]
  public = [
    "password_manager_ui.h",
    "sync_handler.h",
  ]
  public_deps = [
    ":mojo_bindings",
    ":password_manager_ui_handler",
    "//chrome/browser:browser_public_dependencies",
    "//content/public/browser",
    "//mojo/public/cpp/bindings",
    "//ui/webui",
  ]
  deps = [
    ":promo_card",
    ":promo_cards_handler",
    "//base",
    "//chrome/app/theme:chrome_unscaled_resources_grit",
    "//chrome/browser:browser_process_platform_part",
    "//chrome/browser/extensions",
    "//chrome/browser/password_manager",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/profiles/batch_upload",
    "//chrome/browser/resources/password_manager:resources_grit",
    "//chrome/browser/resources/settings_shared:resources_grit",
    "//chrome/browser/signin",
    "//chrome/browser/sync",
    "//chrome/browser/ui:ui_features",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/webui:favicon_source",
    "//chrome/browser/ui/webui:plural_string_handler",
    "//chrome/browser/ui/webui/page_not_available_for_guest",
    "//chrome/browser/ui/webui/sanitized_image:sanitized_image_source",
    "//chrome/browser/ui/webui/settings",
    "//chrome/browser/web_applications",
    "//chrome/common",
    "//components/favicon_base",
    "//components/password_manager/content/common",
    "//components/password_manager/core/browser/features:utils",
    "//components/signin/public/identity_manager",
    "//components/sync/service",
    "//components/user_education/webui",
    "//skia",
    "//ui/base",
    "//ui/webui/tracked_element",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "promo_cards_handler_unittest.cc",
    "sync_handler_unittest.cc",
  ]
  deps = [
    ":password_manager_ui",
    ":password_manager_ui_handler",
    ":promo_card",
    ":promo_cards_handler",
    "//base/test:test_support",
    "//chrome/browser/extensions",
    "//chrome/browser/extensions:test_support",
    "//chrome/browser/password_manager:test_support",
    "//chrome/browser/sync",
    "//chrome/test:test_support",
    "//components/affiliations/core/browser:test_support",
    "//components/password_manager/core/browser",
    "//components/password_manager/core/browser/password_store:test_support",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]

  # password_manager_ui_handler_unittest historically ran on desktop excluding
  # ChromeOS (is_linux || is_mac || is_win).
  if (!is_chromeos) {
    sources += [ "password_manager_ui_handler_unittest.cc" ]
  }

  if (is_chrome_branded) {
    sources += [ "promo_card_unittest.cc" ]
    deps += [
      "//chrome/browser/affiliations",
      "//chrome/browser/ui/webui/password_manager/promo_cards",
      "//chrome/browser/web_applications",
      "//chrome/browser/web_applications:web_app_test",
      "//chrome/browser/web_applications:web_applications_test_support",
      "//chrome/browser/webauthn",
      "//chrome/browser/webauthn:test_support",
      "//chrome/common",
    ]
  }
}
