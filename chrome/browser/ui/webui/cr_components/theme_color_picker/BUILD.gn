source_set("theme_color_picker") {
  sources = [
    "customize_chrome_colors.cc",
    "customize_chrome_colors.h",
  ]
  deps = [
    "//ui/base/mojom",
    "//ui/color",
  ]
  public_deps = [
    "//chrome/browser/new_tab_page/chrome_colors:generate_chrome_colors_info",
    "//chrome/browser/new_tab_page/chrome_colors:selected_colors_info",
  ]
}

if (!is_android) {
  source_set("impl") {
    sources = [
      "theme_color_picker_handler.cc",
      "theme_color_picker_handler.h",
    ]
    public_deps = [
      "//chrome/browser:browser_public_dependencies",
      "//components/themes",
    ]
    deps = [
      ":theme_color_picker",
      "//base",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/search/background",
      "//chrome/browser/themes",
      "//chrome/browser/ui/color:color_headers",
      "//chrome/common:constants",
      "//chrome/common/themes:autogenerated_theme_util",
      "//components/prefs",
      "//content/public/browser",
      "//mojo/public/cpp/bindings",
      "//ui/base",
      "//ui/base/mojom",
      "//ui/color",
      "//ui/color/dynamic_color",
      "//ui/native_theme",
      "//ui/webui/resources/cr_components/theme_color_picker:mojom",
    ]
  }

  source_set("unit_tests") {
    testonly = true
    sources = [ "theme_color_picker_handler_unittest.cc" ]
    deps = [
      ":impl",
      ":theme_color_picker",
      "//base",
      "//base/test:test_support",
      "//chrome/browser/new_tab_page/chrome_colors",
      "//chrome/browser/search/background",
      "//chrome/browser/themes",
      "//chrome/browser/ui/color:color_headers",
      "//chrome/common/themes:autogenerated_theme_util",
      "//chrome/test:test_support",
      "//content/public/browser",
      "//content/test:test_support",
      "//mojo/public/cpp/bindings",
      "//testing/gmock",
      "//testing/gtest",
      "//ui/color/dynamic_color",
    ]
  }
}
