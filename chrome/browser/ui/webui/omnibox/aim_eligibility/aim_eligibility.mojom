module aim_eligibility.mojom;

import "mojo/public/mojom/base/time.mojom";

// The status of the Google Drive disclaimer.
enum DisclaimerState {
  kAccepted,
  kNotAccepted,
  kRestricted,
};

// The status of Google Drive support.
struct DriveStatus {
  // Whether Drive is supported.
  bool is_drive_supported;
  // Whether Drive is eligible by server PEC API response.
  bool is_pec_eligible;
  // Whether the browser identity matches the AIM identity.
  bool is_identity_match;
  // Whether the profile is off-the-record.
  bool is_incognito;
  // Whether the kComposeboxDriveContextMenuOption feature flag is enabled.
  bool is_feature_flag_enabled;
  // Whether the kForceDriveDisclaimerAccepted feature flag is enabled.
  bool is_force_drive_disclaimer_accepted;
  // Whether search content sharing is enabled by policy.
  bool is_search_content_sharing_enabled;
  // The status of the Drive disclaimer.
  DisclaimerState disclaimer_state;
};

// The AIM eligibility state.
struct EligibilityState {
  // Whether AIM is eligible. Combines local and server eligibility, if enabled.
  bool is_eligible;
  // Whether AIM is eligible by enterprise policy.
  bool is_eligible_by_policy;
  // Whether 3rd party AI Chat is eligible by enterprise policy.
  bool is_third_party_eligible_by_policy;
  // Whether AIM is eligible by DSE, i.e., Google is the default search engine.
  bool is_eligible_by_dse;
  // Whether AIM is eligible by server response. Only populated if server
  // eligibility checking is enabled.
  bool is_eligible_by_server;
  // Whether server eligibility checking is enabled.
  bool is_server_eligibility_enabled;
  // Base64 encoded eligibility response proto. Populated if server eligibility
  // checking is enabled.
  string eligibility_response_base64_encoded;
  // Source of the eligibility response, e.g., "Server", "Prefs".
  string eligibility_response_source;
  // Auth type of the eligibility response, e.g., "OAuth" or "Cookie".
  string? eligibility_response_auth_type;
  // Base64url encoded searchbox config proto. Populated if server
  // eligibility checking is enabled.
  string searchbox_config_base64_url_encoded;
  // The status of Google Drive support. Populated asynchronously.
  DriveStatus? drive_status;
  // Last updated time.
  mojo_base.mojom.JSTime last_updated;
};

// WebUI page side handler for receiving calls from the browser.
interface Page {
  // Called when eligibility state changes.
  OnEligibilityStateChanged(EligibilityState state);
  // Called when only Drive status changes. This is needed because Drive status
  // is checked asynchronously and may not be available when eligibility state is
  // queried initially.
  OnDriveStatusChanged(DriveStatus status);
};

// Browser side handler for receiving calls from the page.
interface PageHandler {
  // Gets the current eligibility state.
  GetEligibilityState() => (EligibilityState state);
  // Triggers a server eligibility request.
  RequestServerEligibilityForDebugging();
  // Sets the eligibility response directly from a base64-encoded string.
  // Returns true if the response was successfully parsed and stored in prefs.
  SetEligibilityResponseForDebugging(string base64_encoded_response) => (bool success);
};

// Used by the WebUI page to bootstrap bidirectional communication.
interface PageHandlerFactory {
  // Creates the page handler and binds the pending endpoints.
  CreatePageHandler(pending_remote<Page> page,
                    pending_receiver<PageHandler> handler);
};
