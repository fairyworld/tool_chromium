      "//chrome/common",
      "//chrome/common:channel_info",
      "//components/version_info",
      "//net",
      "//services/network/public/mojom",
      "//ui/base",
      "//ui/color",
      "//ui/gfx",
      "//url",
    ]

    # //chrome/browser/themes and the ntp_resource_cache are desktop-only; their
    # headers are only used under #if !BUILDFLAG(IS_ANDROID) in theme_source.cc.
    if (!is_android) {
      deps += [
        "//chrome/browser/themes",
        "//chrome/browser/ui/webui/ntp:ntp_resource_cache",
      ]
    }

    if (is_chromeos) {
      deps += [
        "//ui/chromeos/styles:cros_styles_resources",
        "//ui/chromeos/styles:cros_tokens_color_mappings",
      ]
    }

    # ThemeSource uses InstantService::ShouldServiceRequest() and InstantService
    # (//chrome/browser/search) constructs ThemeSource — a genuine
    # bidirectional pair. //chrome/browser/search owns the real dep edge and the
    # corresponding allow_circular_includes_from, since search transitively
    # reaches theme_source via the NTP targets.
  }
}

