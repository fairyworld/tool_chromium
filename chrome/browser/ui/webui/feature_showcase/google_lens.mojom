module feature_showcase.mojom;

// Browser-side handler for requests from the Google Lens step WebUI.
interface GoogleLensPageHandler {
  // Grants the necessary permissions to enable Google Lens.
  EnableGoogleLens();
};

// Used by the WebUI to bootstrap WebUI->Browser communication for Google Lens.
interface GoogleLensPageHandlerFactory {
  // The WebUI calls this method when the page is first initialized.
  CreateGoogleLensPageHandler(pending_receiver<GoogleLensPageHandler> handler);
};