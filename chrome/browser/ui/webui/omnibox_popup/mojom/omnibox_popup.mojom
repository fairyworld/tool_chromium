module omnibox_popup.mojom;

import "ui/gfx/geometry/mojom/geometry.mojom";
import "ui/gfx/range/mojom/range.mojom";

// The per-tab input-row state of the Omnibox.
struct OmniboxInputState {
  // An incrementing sequence number generated by C++ to reject stale in-flight
  // selection changes sent back from WebUI during asynchronous state
  // restoration.
  uint32 sequence_number;
  // The text that should be displayed in the Omnibox input field.
  string text;
  // The selection range (or cursor position if start == end) in the input
  // field.
  gfx.mojom.Range selection;
  // Whether the user has edited the text or if it is unedited permanent text.
  bool user_input_in_progress;
  // The full url to show on unelision.
  string full_url;
  // Whether the Omnibox input should have active focus.
  bool is_focused;
};

// Browser-side handler for the Omnibox Popup.
interface PageHandlerFactory {
  // Creates and binds a new PageHandler to handle calls from the WebUI page.
  CreatePageHandler(
      pending_remote<Page> page, pending_receiver<PageHandler> handler);
};

// Browser-side handler for the Omnibox Popup.
interface PageHandler {
  // Opens context menu.
  ShowContextMenu(gfx.mojom.Point point);

  // Closes the Omnibox Popup.
  CloseUI();

  // Called when the WebUI input is manually blurred (e.g. webpage click).
  OnManualBlur(uint32 sequence_number);

  // Called when the selection changes in the WebUI.
  OnSelectionChanged(gfx.mojom.Range selection, uint32 sequence_number);

  // Reverts the omnibox edit model.
  // Discards the call if `sequence_number` is stale.
  Revert(uint32 sequence_number);
};

// The WebUI page for the Omnibox Popup.
interface Page {
  // Called when the popup is shown.
  OnShow();

  // Called when the context menu is closed.
  OnContextMenuClosed();

  // Called by the browser to update the input state (e.g. input text
  // and selection range) of the WebUI Omnibox.
  SetInputState(OmniboxInputState state);
};
