source_set("unit_tests") {
  testonly = true
  sources = [ "new_tab_page_ui_unittest.cc" ]
  deps = [
    ":impl",
    ":new_tab_page",
    "//base",
    "//base/test:test_support",
    "//chrome/browser/new_tab_page",
    "//chrome/test:test_support",
    "//components/search",
    "//components/search_engines",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
  ]
  if (!is_android) {
    sources += [
      "new_tab_page_handler_unittest.cc",
      "untrusted_source_unittest.cc",
    ]
    deps += [
      "//chrome/browser/desktop_to_mobile_promos:utils",
      "//chrome/browser/optimization_guide:test_support",
      "//chrome/browser/search/background",
      "//chrome/browser/search_engines",
      "//chrome/browser/themes",
      "//chrome/browser/ui/hats:test_support",
      "//components/feature_engagement/test:test_support",
      "//components/search_provider_logos",
      "//components/segmentation_platform/embedder/default_model",
      "//components/segmentation_platform/public:test_support",
      "//components/themes",
    ]
  }
}

if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    configs += [ "//build/config/compiler:no_exit_time_destructors" ]
    sources = [
      "new_tab_page_handler_browsertest.cc",
      "webui_ntp_browsertest.cc",
    ]
    deps = [
      ":impl",
      ":new_tab_page",
      "//base",
      "//base/test:test_support",
      "//chrome/browser/new_tab_page",
      "//chrome/browser/search_provider_logos",
      "//chrome/browser/ui:ui_features",
      "//chrome/browser/ui/side_panel",
      "//chrome/browser/ui/side_panel:side_panel_views_dependent",
      "//chrome/browser/ui/webui:webui_util",
      "//chrome/browser/ui/webui/cr_components/most_visited",
      "//chrome/browser/ui/webui/customize_buttons",
      "//chrome/test:test_support",
