import("//build/config/compiler/compiler.gni")
import("//mojo/public/tools/bindings/mojom.gni")
import("//third_party/jni_zero/jni_zero.gni")
import("//ui/webui/webui_features.gni")

assert(enable_webui_ntp)

mojom("mojo_bindings") {
  sources = [ "new_tab_page.mojom" ]
  webui_module_path = "/"

  public_deps = [
    "//chrome/browser/ui/webui/new_tab_page/action_chips:mojo_bindings",
    "//chrome/browser/ui/webui/ntp_microsoft_auth:shared",
    "//components/ntp_tiles:mojo_bindings",
    "//components/omnibox/browser:mojo_bindings",
    "//skia/public/mojom",
    "//ui/webui/resources/cr_components/color_change_listener:mojom",
    "//ui/webui/resources/cr_components/most_visited:mojom",
    "//url/mojom:url_mojom_gurl",
  ]
  if (!is_android) {
    public_deps +=
        [ "//chrome/browser/ui/webui/new_tab_page/ntp_promo:mojo_bindings" ]
  }
}

# Thin public target providing new_tab_page_ui.h and untrusted_source.h without
# heavy deps. Used by targets that include the UI headers but don't need the
# full implementation.
source_set("new_tab_page") {
  public = [
    "new_tab_page_ui.h",
    "untrusted_source.h",
  ]
  public_deps = [
    ":mojo_bindings",
    "//chrome/browser:browser_public_dependencies",
    "//chrome/browser/new_tab_page",
    "//chrome/browser/search/background",
    "//chrome/browser/ui/webui/customize_buttons:mojo_bindings",
    "//chrome/browser/ui/webui/new_tab_page/action_chips",
    "//chrome/browser/ui/webui/new_tab_page/action_chips:mojo_bindings",
    "//components/page_image_service/mojom:mojo_bindings",
    "//components/themes",
    "//ui/webui",
    "//ui/webui/resources/cr_components/composebox:mojo_bindings",
    "//ui/webui/resources/cr_components/help_bubble:mojo_bindings",
    "//ui/webui/resources/js/browser_command:mojo_bindings",
  ]
  if (!is_android) {
    public_deps += [ "//components/user_education/webui" ]
  }
}

