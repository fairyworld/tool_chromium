if (!is_android) {
  source_set("ntp") {
    sources = [
      "core_app_launcher_handler.cc",
      "new_tab_ui.cc",
      "ntp_resource_cache.cc",
      "ntp_resource_cache_factory.cc",
    ]
    public = [
      "core_app_launcher_handler.h",
      "new_tab_ui.h",
      "ntp_resource_cache.h",
      "ntp_resource_cache_factory.h",
    ]
    public_deps = [ "//chrome/browser:browser_public_dependencies" ]
    deps = [
      "//base",
      "//chrome/app:branded_strings",
      "//chrome/app:generated_resources",
      "//chrome/app/theme:theme_resources",
      "//chrome/browser:browser_process",
      "//chrome/browser:browser_process_platform_part",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/signin",
      "//chrome/browser/themes",
      "//chrome/browser/ui:layout_constants",
      "//chrome/browser/ui/color:color_headers",
      "//chrome/browser/ui/webui/util",
      "//chrome/common",
      "//components/keyed_service/core",
      "//components/pref_registry",
      "//components/prefs",
      "//components/search",
      "//components/strings:components_strings",
      "//content/public/browser",
      "//extensions/browser",
      "//extensions/common",
      "//services/network/public/mojom",
      "//ui/base",
      "//ui/native_theme",
      "//url",
    ]

    if (is_chromeos) {
      deps += [
        "//chrome/browser/ash/policy/core",
        "//chromeos/strings:strings_grit",
        "//ui/chromeos",
      ]
    }
  }

  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    sources = [ "new_tab_ui_browsertest.cc" ]
    deps = [
      ":ntp",
      "//chrome/browser/ui",
      "//chrome/test:test_support_ui",
      "//content/test:test_support",
      "//testing/gtest",
    ]
  }
}
