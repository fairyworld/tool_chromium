    "//printing/mojom",
    "//services/device/public/cpp/usb",
    "//services/device/public/mojom:usb",
    "//services/network/public/mojom",
    "//ui/base",
    "//ui/gfx",
    "//ui/gfx/geometry",
    "//ui/shell_dialogs",
    "//ui/web_dialogs",
    "//ui/webui",
  ]

  if (enable_pdf) {
    deps += [
      "//chrome/browser/pdf",
      "//pdf:features",
    ]
  }

  if (use_aura) {
    deps += [ "//ui/aura" ]
  }

  if (is_chromeos) {
    sources += [
      "local_printer_handler_chromeos.cc",
      "print_preview_handler_chromeos.cc",
    ]
    deps += [
      "//ash/constants",
