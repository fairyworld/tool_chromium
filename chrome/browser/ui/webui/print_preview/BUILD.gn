import("//build/config/ui.gni")
import("//chrome/common/features.gni")
import("//extensions/buildflags/buildflags.gni")
import("//pdf/features.gni")
import("//printing/buildflags/buildflags.gni")

assert(enable_print_preview)

# Header-only target exposing the print_preview public API. This is kept
# separate from ":impl" so that //chrome/browser/printing:impl can include
# print_preview headers (e.g. print_preview_ui.h, printer_handler.h) without
# forming a dependency cycle with ":impl" (which depends on printing:impl).
source_set("print_preview") {
  public = [
    "extension_printer_handler.h",
    "parse_data_path.h",
    "pdf_printer_handler.h",
    "policy_settings.h",
    "print_preview_handler.h",
    "print_preview_metrics.h",
    "print_preview_ui.h",
    "print_preview_ui_untrusted.h",
    "print_preview_utils.h",
    "printer_handler.h",
  ]
  public_deps = [
    "//base",
    "//chrome/browser:browser_public_dependencies",
    "//chrome/browser/printing",
    "//chrome/browser/ui/webui",
    "//chrome/services/printing/public/mojom",
    "//components/printing/common:mojo_interfaces",
    "//components/services/print_compositor/public/mojom",
    "//content/public/browser",
    "//extensions/browser",
    "//extensions/common",
    "//mojo/public/cpp/bindings",
    "//printing/buildflags",
    "//printing/mojom",
    "//services/device/public/mojom:usb",
    "//ui/gfx/geometry",
    "//ui/webui",
  ]

  if (is_chromeos) {
    public += [
      "local_printer_handler_chromeos.h",
      "print_preview_handler_chromeos.h",
    ]
    public_deps += [
      "//chrome/browser/ash/printing",
      "//chromeos/crosapi/mojom",
      "//chromeos/printing",
    ]
  } else {
    public += [ "local_printer_handler_default.h" ]
  }
}

