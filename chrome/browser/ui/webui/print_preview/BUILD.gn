  sources = [
    "extension_printer_handler.cc",
    "parse_data_path.cc",
    "pdf_printer_handler.cc",
    "policy_settings.cc",
    "print_preview_handler.cc",
    "print_preview_metrics.cc",
    "print_preview_ui.cc",
    "print_preview_ui_untrusted.cc",
    "print_preview_utils.cc",
    "printer_handler.cc",
  ]
  public_deps = [ "//chrome/browser:browser_public_dependencies" ]
  deps = [
    ":print_preview",
    "//base",
    "//chrome/app:generated_resources",
    "//chrome/browser:bad_message",
    "//chrome/browser:browser_process",
    "//chrome/browser:primitives",
    "//chrome/browser/app_mode",
