<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <ImageView
        android:id="@+id/zero_state_illustration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:src="@drawable/at_memory_zero_state_illustration"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/zero_state_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/autofill_at_memory_zero_state_title"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.Headline2Thick.Primary" />

    <TextView
        android:id="@+id/zero_state_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/autofill_at_memory_zero_state_subtitle"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.TextMedium.Secondary" />
</LinearLayout>
