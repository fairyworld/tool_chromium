<org.chromium.components.browser_ui.widget.chips.ChipView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minHeight="36dp"
    app:textArrangement="vertical"
    app:chipColor="@macro/default_bg_color"
    app:primaryTextAppearance="@style/TextAppearance.TextAccentMediumThick"
    app:secondaryTextAppearance="@style/TextAppearance.TextSmall"
    app:chipStartPadding="@dimen/at_memory_flyout_default_margin"
    app:chipEndPadding="@dimen/at_memory_flyout_default_margin"
    app:chipTopPadding="6dp"
    app:chipBottomPadding="6dp"
    app:verticalInset="0dp"
    style="@style/SuggestionChip" />
