<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_selected="true"
      android:width="@dimen/fusebox_popover_plus_button_bg_width"
      android:height="@dimen/fusebox_popover_plus_button_bg_height">
    <inset
        android:insetTop="6dp"
        android:insetBottom="6dp">
      <shape android:shape="rectangle">
        <solid android:color="@android:color/transparent" />

        <stroke
            android:width="2dp"
            android:color="@macro/default_icon_color" />
        <corners android:radius="@dimen/fusebox_popover_plus_button_bg_corner_radius" />
      </shape>
    </inset>
  </item>

  <item>
    <shape android:shape="rectangle">
      <solid android:color="@android:color/transparent" />
    </shape>
  </item>
</selector>
