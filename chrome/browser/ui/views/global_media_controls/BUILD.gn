source_set("test_support") {
  testonly = true
  public = [ "media_dialog_ui_for_test.h" ]
  sources = [ "media_dialog_ui_for_test.cc" ]
  deps = [
    ":global_media_controls",
    "//chrome/browser/media/router:test_support",
    "//chrome/browser/ui",
    "//chrome/browser/ui/global_media_controls",
    "//chrome/browser/ui/views",
    "//chrome/browser/ui/views/toolbar",
    "//chrome/test:test_support_ui",
    "//components/global_media_controls",
    "//components/media_message_center",
    "//components/media_router/browser:test_support",
    "//testing/gtest",
    "//ui/base:test_support",
    "//ui/views",
    "//ui/views:test_support",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "cast_device_footer_view_unittest.cc",
    "cast_device_selector_view_unittest.cc",
    "media_item_ui_device_selector_view_unittest.cc",
    "media_item_ui_legacy_cast_footer_view_unittest.cc",
    "media_toolbar_button_contextual_menu_unittest.cc",
  ]
  deps = [
    ":global_media_controls",
    ":test_support",
    "//base",
    "//chrome/browser/ui",
    "//chrome/browser/ui/global_media_controls",
    "//chrome/test:test_support",
    "//components/global_media_controls",
    "//components/global_media_controls:test_support",
    "//components/media_message_center",
    "//components/media_router/browser:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/base",
    "//ui/events",
    "//ui/views",
    "//ui/views:test_support",
  ]

  if (is_linux || is_win || is_mac) {
    sources += [ "media_dialog_view_unittest.cc" ]
    deps += [ "//chrome/browser/accessibility" ]
  }

  if (use_nss_certs && is_chromeos) {
    sources += [ "media_item_ui_cast_footer_view_unittest.cc" ]
    deps += [ "//chromeos/ash/components/kcer" ]
  }

  # TODO(crbug.com/40031409): Fix code that adds exit-time destructors and
  # enable the diagnostic by removing this line.
  configs += [ "//build/config/compiler:no_exit_time_destructors" ]
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  # The dump-accessibility-events browser test is not built on ChromeOS:
  # DumpAccessibilityEventsViewsTestBase::EventTestPasses() is empty there,
  # which would leave the parameterized suite uninstantiated and fail the
  # test launcher. This mirrors the original !is_chromeos guard the test
  # had in //chrome/test:browser_tests.
  if (!is_chromeos) {
    sources = [ "media_item_ui_device_selector_view_dump_accessibility_events_browsertest.cc" ]
    deps = [
      ":global_media_controls",
      "//base",
      "//chrome/browser/ui",
      "//chrome/browser/ui/global_media_controls",
      "//chrome/browser/ui/views/accessibility:dump_accessibility_events_views_browsertest_base",
      "//chrome/test:test_support",
      "//components/global_media_controls",
      "//components/global_media_controls:test_support",
      "//components/media_message_center",
      "//content/test:test_support",
      "//ui/accessibility",
      "//ui/views",
    ]
  }
}

