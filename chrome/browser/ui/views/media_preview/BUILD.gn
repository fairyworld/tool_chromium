    "//chrome/browser/ui/views:layout_provider",
    "//chrome/browser/ui/views/media_preview/camera_preview",
    "//chrome/browser/ui/views/media_preview/mic_preview",
    "//chrome/test:test_support",
    "//components/media_effects/test:test_support",
    "//content/test:test_support",
    "//services/audio/public/cpp:test_support",
    "//services/video_capture/public/cpp:mocks",
    "//testing/gmock",
    "//testing/gtest",
    "//ui/views",
