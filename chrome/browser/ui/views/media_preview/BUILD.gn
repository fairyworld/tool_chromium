assert(is_win || is_mac || is_linux)

source_set("media_preview") {
  public = [
    "active_devices_media_coordinator.h",
    "media_coordinator.h",
    "media_preview_metrics.h",
    "media_view.h",
    "media_view_controller_base.h",
    "page_info_previews_coordinator.h",
    "permission_prompt_previews_coordinator.h",
    "scroll_media_preview.h",
  ]
  sources = [
    "active_devices_media_coordinator.cc",
    "media_coordinator.cc",
    "media_preview_metrics.cc",
    "media_view.cc",
    "media_view_controller_base.cc",
    "page_info_previews_coordinator.cc",
    "permission_prompt_previews_coordinator.cc",
    "scroll_media_preview.cc",
  ]
  deps = [
    "//chrome/browser/media/webrtc",
    "//chrome/browser/profiles:profile",
    "//chrome/browser/ui/views:layout_provider",
    "//components/content_settings/core/common",
    "//components/user_prefs",
    "//ui/color:color_headers",
  ]
  public_deps = [
    "//base",
    "//chrome/browser/ui/views/media_preview/camera_preview",
    "//chrome/browser/ui/views/media_preview/mic_preview",
    "//content/public/browser",
    "//media/capture:capture_lib",
    "//ui/base",
    "//ui/views",
  ]

  # media_coordinator.h holds std::optional<CameraCoordinator> and
  # std::optional<MicCoordinator> by value, so it must include (and depend
  # on) the subdir targets. Their public headers in turn include this
  # target's base headers (media_preview_metrics.h,
  # media_view_controller_base.h, media_view.h), which can't be
  # forward-declared. Permit that intra-cluster back-edge here so the
  # subdirs don't need a (cyclic) dependency on this target.
  allow_circular_includes_from = [
    "//chrome/browser/ui/views/media_preview/camera_preview",
    "//chrome/browser/ui/views/media_preview/mic_preview",
  ]
}

