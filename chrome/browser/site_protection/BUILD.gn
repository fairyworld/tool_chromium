import("//build/config/chrome_build.gni")

static_library("utils") {
  sources = [
    "site_familiarity_utils.cc",
    "site_familiarity_utils.h",
  ]

  deps = [
    "//chrome/browser/content_settings:content_settings_factory",
    "//chrome/browser/search_engines",
    "//components/content_settings/browser/ui",
    "//components/content_settings/core/browser",
    "//components/content_settings/core/common",
    "//components/prefs",
    "//components/safe_browsing/core/common:features",
    "//components/safe_browsing/core/common:safe_browsing_prefs",
    "//content/public/browser",
    "//content/public/common",
  ]
}

static_library("site_protection") {
  sources = [
    "site_familiarity_fetcher.cc",
    "site_familiarity_fetcher.h",
    "site_familiarity_heuristic_name.h",
    "site_familiarity_process_selection_deferring_condition.cc",
    "site_familiarity_process_selection_deferring_condition.h",
    "site_familiarity_process_selection_user_data.cc",
    "site_familiarity_process_selection_user_data.h",
    "site_protection_metrics.h",
    "site_protection_metrics_observer.cc",
    "site_protection_metrics_observer.h",
  ]

  deps = [
    ":utils",
    "//base",
    "//chrome/browser:browser_process",
    "//chrome/browser/content_settings:content_settings_factory",
    "//chrome/browser/engagement",
    "//chrome/browser/history",
    "//chrome/browser/profiles",
    "//chrome/browser/safe_browsing",
    "//chrome/browser/search_engines",
    "//components/content_settings/browser/ui",
    "//components/content_settings/core/browser",
    "//components/content_settings/core/common",
    "//components/history/core/browser",
    "//components/keyed_service/core",
    "//components/prefs",
    "//components/safe_browsing/content/browser/web_ui",
    "//components/safe_browsing/core/browser/db:database_manager",
    "//components/safe_browsing/core/common",
    "//components/safe_browsing/core/common:safe_browsing_prefs",
    "//components/search_engines",
    "//components/site_engagement/content",
    "//content/public/browser",
    "//net",
    "//url",
  ]
}

if (!is_android) {
  source_set("unit_tests") {
    testonly = true

    sources = [
      "site_familiarity_process_selection_deferring_condition_unittest.cc",
      "site_familiarity_utils_unittest.cc",
      "site_protection_metrics_observer_unittest.cc",
    ]

    deps = [
      ":site_protection",
      ":utils",
      "//base",
      "//chrome/browser:browser_process",
      "//chrome/browser/content_settings",
      "//chrome/browser/engagement",
      "//chrome/browser/history",
      "//chrome/browser/profiles",
      "//chrome/browser/profiles:profile",
      "//chrome/browser/safe_browsing:test_support",
      "//chrome/browser/search_engines",
      "//chrome/browser/ui/safety_hub:test_support",
      "//chrome/common:chrome_features",
      "//chrome/common:constants",
      "//chrome/test:test_support",
      "//components/content_settings/core/common",
      "//components/history/core/browser",
      "//components/history/core/test",
      "//components/keyed_service/core",
      "//components/prefs",
      "//components/safe_browsing/core/browser/db:test_database_manager",
      "//components/safe_browsing/core/common:features",
      "//components/safe_browsing/core/common:safe_browsing_prefs",
      "//components/search_engines",
      "//components/site_engagement/content",
      "//components/sync_preferences:test_support",
      "//components/ukm:test_support",
      "//content/public/browser",
      "//content/public/common",
      "//content/test:test_support",
      "//testing/gmock",
      "//testing/gtest",
    ]
  }
}
