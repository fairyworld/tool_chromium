# Foundational cert-verification browser-test base classes, used across many
# directories. Kept in a dedicated target so consumers can depend on it without
# pulling all of //chrome/test:test_support_ui.
source_set("cert_verifier_test_support") {
  testonly = true

  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [
    "cert_verifier_platform_browser_test.cc",
    "cert_verifier_platform_browser_test.h",
  ]

  public_deps = [ "//content/test:test_support" ]

  if (is_android) {
    public_deps += [ "//chrome/test:test_support_ui_android" ]
  } else {
    sources += [
      "cert_verifier_browser_test.cc",
      "cert_verifier_browser_test.h",
    ]
    public_deps += [ "//chrome/test:test_support_ui" ]
  }
}

