import("//ui/webui/resources/tools/build_webui.gni")

assert(!is_android && !is_ios)

build_webui("build") {
  grd_prefix = "omnibox_everywhere"
  static_files = [ "omnibox_everywhere.html" ]
  ts_files = [
    "composebox.html.ts",
    "composebox.ts",
    "app.html.ts",
    "app.ts",
    "omnibox.html.ts",
    "omnibox.ts",
    "omnibox_everywhere.ts",
  ]
  css_files = [
    "composebox.css",
    "app.css",
    "omnibox.css",
  ]
  ts_deps = [
    "//third_party/lit/v3_0:build_ts",
    "//ui/webui/resources/cr_components/composebox:build_ts",
    "//ui/webui/resources/cr_components/search:build_ts",
    "//ui/webui/resources/cr_components/searchbox:build_ts",
    "//ui/webui/resources/cr_elements:build_ts",
    "//ui/webui/resources/js:build_ts",
    "//ui/webui/resources/mojo:build_ts",
  ]

  ts_definitions = [ "//tools/typescript/definitions/pending.d.ts" ]

  webui_context_type = "trusted"
}
