import("//build/config/chromeos/args.gni")

assert(!is_android)

source_set("desktop_session_duration") {
  sources = [
    "audible_contents_tracker.h",
    "chrome_visibility_observer.h",
    "desktop_session_duration_tracker.h",
  ]
  deps = [
    "//base",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/tabs:tab_strip_model_observer",
  ]
}

source_set("browser_tests") {
  testonly = true

  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [ "audible_contents_tracker_browsertest.cc" ]

  deps = [
    ":desktop_session_duration",
    "//base",
    "//chrome/test:test_support",
    "//chrome/test:test_support_ui",
    "//content/test:test_support",
    "//testing/gtest",
  ]
}

if (!is_chromeos_device) {
  source_set("interactive_ui_tests") {
    testonly = true

    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [ "chrome_visibility_observer_interactive_uitest.cc" ]

    deps = [
      ":desktop_session_duration",
      "//base",
      "//chrome/browser:chrome_browser_main",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//content/test:test_support",
      "//testing/gtest",
    ]
  }
}
