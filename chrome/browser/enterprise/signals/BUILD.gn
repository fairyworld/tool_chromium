source_set("unit_tests") {
  testonly = true

  sources = [ "user_delegate_impl_unittest.cc" ]

  deps = [
    "//base",
    "//chrome/browser/enterprise:impl",
    "//chrome/browser/enterprise/connectors/device_trust:test_support",
    "//chrome/test:test_support",
    "//testing/gtest",
  ]

  if (!is_android) {
    sources += [ "client_certificate_fetcher_unittest.cc" ]
    deps += [ "//chrome/browser/content_settings:content_settings_factory" ]
  }
}

if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [ "profile_signals_collector_browsertest.cc" ]

    deps = [
      "//base",
      "//chrome/browser/enterprise:impl",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//content/test:test_support",
      "//testing/gmock",
    ]
  }
}

if (is_android) {
  source_set("android_browsertests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [ "profile_signals_collector_browsertest.cc" ]

    deps = [
      "//base",
      "//chrome/browser/enterprise:impl",
      "//chrome/test:test_support",
      "//content/test:test_support",
      "//testing/gmock",
    ]
  }
}
