import("//build/config/chromeos/args.gni")

source_set("unit_tests") {
  testonly = true

  sources = []
  deps = []

  if (is_linux || is_mac || is_win || is_android) {
    sources += [
      "action_runner_unittest.cc",
      "action_unittest.cc",
    ]
    deps += [
      "//base",
      "//chrome/browser/enterprise:impl",
      "//chrome/test:test_support",
      "//testing/gtest",
    ]
  }
}

if (!is_android && !is_chromeos_device && (is_win || is_mac || is_linux)) {
  source_set("interactive_ui_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [ "idle_service_interactive_uitest.cc" ]

    deps = [
      "//base",
      "//chrome/browser/enterprise:impl",
      "//chrome/browser/ui/focus",
      "//chrome/browser/user_education",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//content/test:test_support",
      "//testing/gmock",
      "//ui/base:ozone_buildflags",
    ]
  }
}
