source_set("unit_tests") {
  testonly = true

  sources = []
  deps = []

  if (is_linux || is_mac || is_win) {
    sources += [ "chrome_web_store_navigation_throttle_unittest.cc" ]
    deps += [
      "//base",
      "//chrome/browser/enterprise:impl",
      "//chrome/test:test_support",
      "//components/enterprise:test_support",
      "//testing/gtest",
    ]
  }
}
