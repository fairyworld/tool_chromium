source_set("unit_tests") {
  testonly = true

  sources = []
  deps = []

  if (is_linux || is_mac || is_win) {
    sources += [ "saml_response_parser_unittest.cc" ]
    deps += [
      "//base",
      "//chrome/browser/enterprise:impl",
      "//chrome/test:test_support",
      "//testing/gtest",
    ]
  }
}

if (!is_android && (is_win || is_mac || is_linux)) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [
      "oidc_auth_response_capture_navigation_throttle_browsertest.cc",
      "profile_management_navigation_throttle_browsertest.cc",
    ]

    deps = [
      "//base",
      "//chrome/browser/enterprise:impl",
      "//chrome/browser/ui/signin",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//content/test:test_support",
      "//testing/gmock",
    ]
  }
}
