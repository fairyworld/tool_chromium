source_set("signals") {
  configs += [ "//components/enterprise:extra_warnings" ]

  public = [
    "signals_filterer.h",
    "signals_service.h",
  ]

  public_deps = [
    "//base",
    "//chrome/browser/enterprise/connectors/device_trust/attestation/common:types",
    "//chrome/browser/enterprise/core",
  ]
}

source_set("test_support") {
  testonly = true
  configs += [ "//components/enterprise:extra_warnings" ]

  sources = [
    "mock_signals_filterer.cc",
    "mock_signals_filterer.h",
    "mock_signals_service.cc",
    "mock_signals_service.h",
  ]

  public_deps = [
    ":signals",
    "//testing/gmock",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = []
  deps = []

  if (is_linux || is_chromeos || is_mac || is_win) {
    sources += [
      "signals_filterer_unittest.cc",
      "signals_service_impl_unittest.cc",
    ]
    deps += [
      ":test_support",
      "//base",
      "//chrome/browser/enterprise:impl",
      "//chrome/browser/enterprise/connectors/device_trust/signals/decorators/common:test_support",
      "//chrome/test:test_support",
      "//testing/gtest",
    ]
  }

  if (is_chromeos) {
    sources += [ "ash/ash_signals_filterer_unittest.cc" ]
  }
}

if (!is_android && is_chromeos) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [ "decorators/ash/ash_signals_decorator_browsertest.cc" ]

    deps = [
      "//base",
      "//chrome/browser:browser_process_platform_part",
      "//chrome/browser/ash/policy/core:test_support",
      "//chrome/browser/enterprise:impl",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//chromeos/ash/components/dbus/shill",
      "//chromeos/ash/components/system",
      "//content/test:test_support",
      "//testing/gmock",
    ]
  }
}
