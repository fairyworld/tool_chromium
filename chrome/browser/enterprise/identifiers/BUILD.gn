source_set("unit_tests") {
  testonly = true

  sources = [ "profile_id_service_factory_unittest.cc" ]

  deps = [
    "//base",
    "//chrome/browser/enterprise:impl",
    "//chrome/test:test_support",
    "//components/enterprise:test_support",
    "//testing/gtest",
  ]

  if (is_chromeos) {
    deps += [ "//chromeos/ash/components/system" ]
  }
}
