source_set("watermark_lib") {
  sources = [
    "settings.cc",
    "settings.h",
    "watermark_features.cc",
    "watermark_features.h",
  ]

  deps = [
    "//chrome/common:channel_info",
    "//components/enterprise/connectors/core",
    "//components/enterprise/watermarking",
    "//components/prefs",
    "//components/version_info",
    "//ui/views",
  ]
}

executable("watermark_app") {
  testonly = true
  configs += [ "//components/enterprise:extra_warnings" ]

  sources = [
    "example_app.cc",
    "watermark_example.cc",
    "watermark_example.h",
  ]

  deps = [
    ":watermark_lib",
    "//base",
    "//base/test:test_support",
    "//build/win:default_exe_manifest",
    "//chrome/browser/enterprise/data_protection:data_protection_view_lib",
    "//ui/base/metadata",
    "//ui/color:mixers",
    "//ui/gfx",
    "//ui/resources:ui_test_pak",
    "//ui/views",
    "//ui/views/examples:views_examples_lib",
    "//ui/views/examples:views_examples_proc",
  ]

  defines = [ "VIEWS_EXAMPLES_IMPLEMENTATION" ]
}

if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]
    configs += [ "//components/enterprise:extra_warnings" ]

    sources = [ "watermark_browsertest.cc" ]

    deps = [
      ":watermark_lib",
      "//base",
      "//chrome/browser/ui:ui_features",
      "//chrome/browser/ui/webui/watermark",
      "//chrome/test:test_support",
      "//chrome/test:test_support_ui",
      "//components/enterprise/data_controls/core/browser:test_support",
      "//components/safe_browsing/core/browser/realtime:test_support",
      "//content/test:test_support",
      "//testing/gmock",
    ]
  }
}
